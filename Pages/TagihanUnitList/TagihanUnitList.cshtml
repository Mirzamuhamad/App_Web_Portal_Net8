@page
@model Pages.TagihanUnitList.TagihanUnitListModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "Unit List";
}

<div class="min-h-screen bg-slate-50 pb-20" >

   <div class="bg-white border-b sticky top-0 z-30 px-2 sm:px-6 py-3 shadow-sm">
    <div class="mx-auto flex items-center justify-between">
        <!-- Sisi Kiri -->
        <div class="flex items-center gap-4">
            <a href="/index"
                class="w-10 h-10 flex items-center justify-center bg-slate-100 rounded-2xl text-slate-500 hover:bg-red-50 hover:text-red-600 transition">
                <i class="ri-arrow-left-line text-xl"></i>
            </a>
        </div>

        <!-- Sisi Kanan (Tombol History) -->
         <a href="/HistoryTagihanUnitList/HistoryTagihanUnitList" 
           class="flex items-center gap-2 px-4 py-2 bg-slate-100 rounded-xl text-slate-600 hover:bg-teal-50 hover:text-teal-600 transition text-sm font-medium">
            <i class="ri-history-line text-lg"></i>
            <span>History</span>
        </a>
    </div>
</div>

    <div class="grid grid-cols-1 gap-4 pt-5 sm:pt-5  mx-auto px-2 sm:px-6">
        @foreach (var item in Model.UnitItems)
        {
            <a asp-page="/TagihanUnitList/TagihanUnitDetailPage/TagihanUnitDetailPage" 
            asp-route-id="@item.KavlingId" 
            class="block transform hover:scale-[1.002] transition duration-200">
                
                <!-- Card Utama mengikuti style image_c1b69e.png (Rounded besar, shadow lembut, border gray tipis) -->
                <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-gray-100 p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 relative overflow-hidden">
                    
                    <!-- Sisi Kiri: Informasi Kavling -->
                    <div class="flex items-start gap-3 flex-1 min-w-0">
                        <!-- Indicator Vertikal red/Slate sesuai status tagihan -->
                        <div class="w-1.5 h-10 rounded-full flex-shrink-0 mt-0.5 @(item.TotalAmountKavling <= 0 ? "bg-slate-300" : "bg-red-500")"></div>
                        
                        <div class="flex-1 min-w-0">
                            <span class="text-[10px] sm:text-xs font-bold text-gray-400 uppercase tracking-wider block mb-0.5">Informasi Tagihan Kavling</span>
                            <h3 class="text-base sm:text-lg font-bold truncate @(item.TotalAmountKavling <= 0 ? "text-slate-500" : "text-red-600")">
                                @item.KavlingCode
                            </h3>
                            
                            <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-gray-400">
                                @if (item.TotalAmountKavling <= 0)
                                {
                                    <span class="text-emerald-600 font-medium flex items-center gap-1">
                                        <i class="fa-solid fa-circle-check"></i> Belum ada tagihan / Lunas
                                    </span>
                                }
                                else
                                {
                                    <span class="flex items-center gap-1">
                                        <i class="fa-solid fa-ruler-combined text-[10px]"></i> Luas: @item.Luas.ToString("N2", new System.Globalization.CultureInfo("id-ID")) m²
                                    </span>
                                    <span class="text-amber-600 font-medium flex items-center gap-1">
                                        <i class="fa-solid fa-circle-info text-[10px]"></i> Klik untuk detail tagihan
                                    </span>
                                }
                            </div>
                        </div>
                    </div>

                    <!-- Sisi Kanan: Card Total Tagihan (Diubah menjadi Outline Clean Style & Tetap Membawa Ikon Wallet) -->
                    <div class="border rounded-xl p-3 flex items-center justify-between gap-4 w-full sm:w-[260px] flex-shrink-0 transition-colors @(item.TotalAmountKavling <= 0 ? "border-slate-100 bg-slate-50/50 text-slate-400" : "border-red-500/30 bg-red-50/10 text-gray-700")">
                        
                        <!-- Ikon Wallet Tetap Dipertahankan -->
                        <div class="flex items-center justify-center w-8 h-8 rounded-lg flex-shrink-0 @(item.TotalAmountKavling <= 0 ? "bg-slate-100 text-slate-400" : "bg-red-50 text-red-500")">
                            <i class="fa-solid fa-wallet text-sm"></i>
                        </div>

                        <!-- Nilai Tagihan -->
                        <div class="text-right flex-1 min-w-0">
                            <p class="text-[9px] uppercase tracking-wider text-gray-400 font-semibold leading-none mb-1.5">Total Tagihan Belum Dibayar</p>
                            <h2 class="text-base sm:text-lg font-bold tracking-tight text-gray-600 whitespace-nowrap">
                                <span class="text-xs font-semibold @(item.TotalAmountKavling <= 0 ? "text-slate-400" : "text-red-500") mr-0.5">Rp</span>@item.TotalAmountKavling.ToString("N0", new System.Globalization.CultureInfo("id-ID"))
                            </h2>
                        </div>
                        
                    </div>

                </div>
            </a>
        }
    </div>
    
</div>