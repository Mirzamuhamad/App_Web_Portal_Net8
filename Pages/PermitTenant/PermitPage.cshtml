@page
@model TestLandingPageNet8.Pages.PermitPage.PermitPageModel
@{
    Layout = "_Layout";
}

<div class="min-h-screen bg-slate-50 pb-20" x-data="permitLogic()">

    <div class="bg-white border-b sticky top-0 z-30 px-4 sm:px-6 py-4 shadow-sm">
        <div class="mx-auto flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 flex items-center justify-center bg-teal-50 rounded-xl text-teal-600">
                    <i class="ri-file-shield-2-line text-2xl"></i>
                </div>
                <div>
                    <h1 class="text-xl font-bold text-slate-800">Upload Dokumen</h1>
                    <p class="text-xs text-slate-400">Laporkan dokumen yang diperlukan</p>
                </div>
            </div>
            <button @@click="isModalOpen = true" class="bg-teal-600 text-white px-5 py-2.5 rounded-2xl text-sm font-bold shadow-lg shadow-teal-100 hover:bg-teal-700 transition">
                + Upload Dokumen
            </button>
        </div>
    </div>

    <div class="px-2 sm:px-6 mt-8 ">
        <h2 class="text-xs text-slate-400 font-bold uppercase tracking-widest mb-4">Riwayat Pelaporan Dokumen</h2>

        <div class="grid grid-cols-1 gap-4">
            @if (Model.PermitHistory != null && Model.PermitHistory.Any())
            {
                @foreach (var item in Model.PermitHistory)
                {
                    <div @@click="openDetail({ 
                            id: '@item.PermitId', 
                            transNmbr: '@item.PermitTransNmbr', 
                            type: '@item.PermitType', 
                            date: '@item.ProposedDate.ToString("dd MMM yyyy")', 
                            status: '@item.PermitStatus',
                            description: '@item.Description', 
                            notes: '@item.NotesFromManagement',
                            documents: '@item.DocumentUrls' ? '@item.DocumentUrls'.split(',') : [],
                            docCount: '@item.DocumentCount',
                            kavlingCode: '@item.KavlingCode'
                         })"
                         class="group p-4 border border-slate-100 rounded-2xl bg-white hover:border-teal-200 hover:shadow-md transition-all duration-300 flex justify-between items-center cursor-pointer">

                        <div class="flex items-start gap-4">
                            <div class="hidden md:flex w-12 h-12 bg-slate-50 rounded-xl items-center justify-center border border-slate-100 shadow-sm text-teal-600 group-hover:bg-teal-600 group-hover:text-white transition-colors">
                                <i class="ri-article-line text-xl"></i>
                            </div>

                            <div>
                                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">@item.PermitTransNmbr</span>
                                <h3 class="font-bold text-slate-700 text-base group-hover:text-teal-700 transition-colors">@item.PermitType</h3>
                                <p class="text-xs text-slate-400 mt-1 flex items-center gap-3">
                                    @* <span><i class="ri-calendar-line mr-1"></i> Tgl Pelaksanaan: @item.ProposedDate.ToString("dd MMM yyyy")</span> *@
                                    <span><i class="ri-attachment-2 mr-1"></i> @item.DocumentCount Dokumen</span>
                                </p>
                            </div>
                        </div>

                        @* <span class="px-3 py-1.5 rounded-lg border text-[10px] font-extrabold uppercase tracking-wider
                            @(item.PermitStatus == "Pending" ? "bg-amber-50 text-amber-600 border-amber-100" : 
                              item.PermitStatus == "Approved" ? "bg-emerald-50 text-emerald-600 border-emerald-100" : 
                              item.PermitStatus == "Review" ? "bg-blue-50 text-blue-600 border-blue-100" : "bg-rose-50 text-rose-600 border-rose-100")">
                            @item.PermitStatus
                        </span> *@
                    </div>
                }
            }
            else
            {
                <div class="py-20 text-center bg-white rounded-[2rem] border-2 border-dashed border-slate-100">
                    <i class="ri-file-list-3-line text-5xl text-slate-200"></i>
                    <p class="text-slate-400 font-bold mt-2">Belum ada pelaporan dokumen yang di upload</p>
                </div>
            }
        </div>
    </div>
    
    <div x-show="isModalOpen"
         class="fixed inset-0 z-[110] flex items-end sm:items-center justify-center bg-slate-900/60 backdrop-blur-sm"
         x-cloak>

        <div class="bg-white w-full max-w-2xl rounded-t-[1.5rem] sm:rounded-[2rem] shadow-2xl flex flex-col max-h-[90vh] overflow-hidden"
             @@click.away="isModalOpen = false">

            <div class="flex justify-between items-center px-2 sm:px-6 py-3 sm:py-5 border-b border-slate-50">
                <h3 class="text-xl text-slate-800 font-semibold">Upload Pelaporan Dokumen</h3>
                <button @@click="isModalOpen = false"
                        class="w-10 h-10 flex items-center justify-center text-slate-400 hover:bg-slate-50 rounded-full text-2xl transition">&times;</button>
            </div>

            <form x-ref="form" enctype="multipart/form-data"
                  class="flex-1 overflow-y-auto px-2 sm:px-6 space-y-4 no-scrollbar bg-white py-4">
                @Html.AntiForgeryToken()

                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Pilih Unit / Kavling</label>
                    <div class="relative">
                        <select name="Input.KavlingId" required
                                class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition appearance-none cursor-pointer">
                            @* <option value="">Pilih Unit</option> *@
                            @foreach(var unit in Model.MyUnits)
                            {
                                <option value="@unit.KavlingId">@unit.KavlingCode (@unit.Kawasan)</option>
                            }
                        </select>
                        <i class="ri-arrow-down-s-line absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none"></i>
                    </div>
                </div>

                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Jenis Izin</label>
                    <input type="text" name="Input.PermitType" required placeholder="Contoh: Pelaporan Dokumen"
                           class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition">
                </div>

                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Detail Keperluan</label>
                    <textarea name="Input.Description" required rows="4"
                              placeholder="Jelaskan detail permohonan izin..."
                              class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 outline-none transition resize-none"></textarea>
                </div>

                <div class="space-y-3">
                    <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Lampiran Foto/Dokumen (Maks. 5)</label>
                    <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
                        <template x-for="(img, index) in previews" :key="index">
                            <div class="relative aspect-square rounded-2xl overflow-hidden border border-slate-100 group shadow-sm">
                                <img :src="img" class="w-full h-full object-cover">
                                <button type="button" @@click="removeImage(index)"
                                        class="absolute top-1 right-1 bg-rose-500/90 text-white w-6 h-6 rounded-lg backdrop-blur-sm flex items-center justify-center hover:bg-rose-600 transition">
                                    <i class="ri-close-line"></i>
                                </button>
                            </div>
                        </template>

                        <label x-show="previews.length < 5"
                               class="aspect-square rounded-2xl border-2 border-dashed border-slate-200 flex flex-col items-center justify-center cursor-pointer hover:border-teal-500 hover:bg-teal-50/50 transition group">
                            <i class="ri-image-add-line text-2xl text-slate-300 group-hover:text-teal-500"></i>
                            <span class="text-[9px] font-bold text-slate-400 group-hover:text-teal-600 mt-1 uppercase">Upload</span>
                            <input type="file" name="Input.Attachments" multiple accept=".jpg,.jpeg,.png,.pdf" class="hidden"
                                   @@change="previewImages($event)">
                        </label>
                    </div>
                </div>

                <div x-show="compressing" class="p-2 sm:p-4 bg-teal-50 rounded-2xl border border-teal-100">
                    <div class="flex justify-between items-center mb-2">
                        <span class="text-[10px] font-bold text-teal-600 uppercase tracking-widest">Memproses File...</span>
                        <span class="text-xs font-bold text-teal-600" x-text="compressProgress + '%'"></span>
                    </div>
                    <div class="w-full bg-slate-200 rounded-full h-1.5 overflow-hidden">
                        <div class="bg-teal-500 h-full transition-all duration-300" :style="'width: ' + compressProgress + '%'"></div>
                    </div>
                </div>
            </form>

            <div class="p-6 border-t border-slate-50 bg-slate-50/50">
                <button type="button" :disabled="loading" @@click="submitForm()"
                        class="w-full bg-teal-600 hover:bg-teal-700 disabled:bg-slate-300 text-white font-bold py-4 rounded-2xl shadow-lg shadow-teal-200 transition-all flex items-center justify-center gap-3 active:scale-[0.98]">
                    <template x-if="loading">
                        <i class="ri-loader-4-line animate-spin text-xl"></i>
                    </template>
                    <span x-text="loading ? 'Sedang Mengirim...' : 'Kirim Permohonan'"></span>
                </button>
            </div>
        </div>
    </div>

    <div x-show="showDetail" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center p-4 overflow-y-auto"
         x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">

        <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm" @@click="showDetail = false"></div>

        <div class="relative bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden"
             x-transition:enter="transition ease-out duration-300 transform" x-transition:enter-start="opacity-0 scale-95 translate-y-4" x-transition:enter-end="opacity-100 scale-100 translate-y-0">

            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <div>
                    <span class="text-[10px] font-bold text-teal-600 uppercase tracking-widest" x-text="selectedPermit.transNmbr"></span>
                    <h3 class="text-lg font-bold text-slate-700 block" x-text="selectedPermit.type"></h3>
                </div>
                <button @@click="showDetail = false" class="w-10 h-10 flex items-center justify-center bg-white rounded-xl text-slate-400 hover:text-rose-500 shadow-sm transition">
                    <i class="ri-close-line text-2xl"></i>
                </button>
            </div>

            <div class="p-6 overflow-y-auto max-h-[70vh] no-scrollbar">
                <div class="space-y-6">
                    <div class="grid grid-cols-2 gap-4 pb-6 border-b border-dashed border-slate-200">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Unit / Kavling</label>
                            <div class="text-slate-600 font-semibold mt-1" x-text="selectedPermit.kavlingCode"></div>
                        </div>
                        @* <div class="text-right">
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Status Permohonan</label>
                            <div class="mt-1">
                                <span :class="selectedPermit.status === 'Pending' ? 'bg-amber-50 text-amber-600 border-amber-100' : 
                                              selectedPermit.status === 'Approved' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : 
                                              selectedPermit.status === 'Review' ? 'bg-blue-50 text-blue-600 border-blue-100' : 'bg-rose-50 text-rose-600 border-rose-100'"
                                      class="px-3 py-1 text-[10px] font-extrabold rounded-lg border uppercase tracking-wider inline-block"
                                      x-text="selectedPermit.status"></span>
                            </div>
                        </div> *@
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Detail Keperluan</label>
                        <div class="bg-slate-50 border border-slate-100 rounded-2xl p-4 text-sm text-slate-600 leading-relaxed italic">
                            <i class="ri-chat-quote-line text-teal-300 text-xl block mb-2"></i>
                            <span x-text="selectedPermit.description"></span>
                        </div>
                    </div>

                    <div x-show="selectedPermit.notes">
                        <label class="block text-[10px] font-bold text-rose-400 uppercase tracking-wider mb-2">Catatan Pengelola</label>
                        <div class="bg-rose-50/50 border border-rose-100 rounded-2xl p-4 text-sm text-rose-700 leading-relaxed">
                            <span x-text="selectedPermit.notes"></span>
                        </div>
                    </div>

                    <div>
                        <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-3">
                            Lampiran Dokumen (<span x-text="selectedPermit.docCount || 0"></span>)
                        </label>
                        <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
                            <template x-if="selectedPermit.docCount > 0">
                                <template x-for="(doc, index) in selectedPermit.documents" :key="index">
                                    <div @@click="openLightbox(index)" class="aspect-square rounded-2xl overflow-hidden border-2 border-slate-100 p-1 bg-white shadow-sm cursor-zoom-in hover:border-teal-500 transition-all group">
                                        <template x-if="doc.toLowerCase().endsWith('.pdf')">
                                            <div class="w-full h-full flex flex-col items-center justify-center bg-slate-50 rounded-xl">
                                                <i class="ri-file-pdf-fill text-3xl text-rose-500"></i>
                                                <span class="text-[8px] text-slate-400 font-semibold mt-1">PDF Document</span>
                                            </div>
                                        </template>
                                        <template x-if="!doc.toLowerCase().endsWith('.pdf')">
                                            <img :src="doc" class="w-full h-full object-cover rounded-xl group-hover:scale-110 transition-transform duration-500">
                                        </template>
                                    </div>
                                </template>
                            </template>
                            <template x-if="!selectedPermit.docCount || selectedPermit.docCount == 0">
                                <div class="col-span-full py-10 border-2 border-dashed border-slate-100 rounded-3xl flex flex-col items-center justify-center text-slate-300">
                                    <i class="ri-image-line text-4xl"></i>
                                    <span class="text-xs mt-2 font-medium">Tidak ada lampiran dokumen</span>
                                </div>
                            </template>
                        </div>
                    </div>
                </div>
            </div>

            <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-end">
                <button @@click="showDetail = false" class="px-8 py-3 bg-teal-600 text-white rounded-2xl font-bold shadow-lg shadow-teal-100">Tutup</button>
            </div>
        </div>
    </div>

    <div x-show="showLightbox" class="fixed inset-0 z-[200] bg-black/95 flex items-center justify-center p-4" x-cloak @@keydown.window.escape="showLightbox = false">
        <button @@click="showLightbox = false" class="absolute top-6 right-6 text-white/70 hover:text-white transition z-[210]"><i class="ri-close-line text-4xl"></i></button>
        <button x-show="selectedPermit.documents.length > 1" @@click="prevImg()" class="absolute left-4 top-1/2 w-12 h-12 bg-white/10 rounded-full text-white hover:bg-white/20"><i class="ri-arrow-left-s-line text-3xl"></i></button>

        <div class="max-w-4xl w-full h-[80vh] flex flex-col items-center justify-center">
            <template x-if="selectedPermit.documents[currentImgIndex]?.toLowerCase().endsWith('.pdf')">
                <div class="text-center bg-white p-8 rounded-3xl shadow-xl flex flex-col items-center">
                    <i class="ri-file-pdf-fill text-6xl text-rose-500 mb-4"></i>
                    <p class="text-slate-800 font-bold mb-4">Dokumen Lampiran PDF</p>
                    <a :href="selectedPermit.documents[currentImgIndex]" target="_blank" class="px-6 py-2.5 bg-teal-600 hover:bg-teal-700 text-white rounded-xl text-sm font-bold shadow transition">Buka File PDF</a>
                </div>
            </template>
            <template x-if="!selectedPermit.documents[currentImgIndex]?.toLowerCase().endsWith('.pdf')">
                <img :src="selectedPermit.documents[currentImgIndex]" class="max-w-full max-h-full object-contain shadow-2xl rounded-lg">
            </template>
            
            <div class="mt-4 text-white/50 text-sm font-medium">
                <span x-text="currentImgIndex + 1"></span> / <span x-text="selectedPermit.documents.length"></span>
            </div>
        </div>

        <button x-show="selectedPermit.documents.length > 1" @@click="nextImg()" class="absolute right-4 top-1/2 w-12 h-12 bg-white/10 rounded-full text-white hover:bg-white/20"><i class="ri-arrow-right-s-line text-3xl"></i></button>
    </div>

</div>

<script>
    function permitLogic() {
        return {
            isModalOpen: false,
            showDetail: false,
            showLightbox: false,
            loading: false,
            currentImgIndex: 0,
            selectedPermit: { id: '', transNmbr: '', type: '', status: '', description: '', notes: '', documents: [], kavlingCode: '', date: '', docCount: 0 },

            previews: [],
            compressedFiles: [],
            compressing: false,
            compressProgress: 0,

            openDetail(data) {
                this.selectedPermit = data;
                this.showDetail = true;
            },
            openLightbox(index) {
                this.currentImgIndex = index;
                this.showLightbox = true;
            },
            prevImg() {
                this.currentImgIndex = (this.currentImgIndex > 0) ? this.currentImgIndex - 1 : this.selectedPermit.documents.length - 1;
            },
            nextImg() {
                this.currentImgIndex = (this.currentImgIndex < this.selectedPermit.documents.length - 1) ? this.currentImgIndex + 1 : 0;
            },

            async previewImages(event) {
                const files = Array.from(event.target.files);
                if (this.previews.length + files.length > 5) {
                    alert('Maksimal 5 file lampiran.');
                    return;
                }

                this.compressing = true;
                this.compressProgress = 0;

                for (const file of files) {
                    // Jika file PDF, langsung masukkan ke preview tanpa image-compression
                    if (file.type === "application/pdf" || file.name.toLowerCase().endsWith('.pdf')) {
                        this.compressedFiles.push(file);
                        this.previews.push(""); // Placeholder untuk non-image preview
                        this.compressProgress = 100;
                        continue;
                    }

                    const options = {
                        maxSizeMB: 1,
                        maxWidthOrHeight: 1280,
                        useWebWorker: true,
                        onProgress: (p) => { this.compressProgress = p; }
                    };

                    try {
                        const compressedFile = await imageCompression(file, options);
                        this.compressedFiles.push(compressedFile);

                        const reader = new FileReader();
                        reader.onload = (e) => this.previews.push(e.target.result);
                        reader.readAsDataURL(compressedFile);
                    } catch (error) {
                        console.error("Gagal kompres:", error);
                    }
                }

                setTimeout(() => {
                    this.compressing = false;
                    this.compressProgress = 0;
                }, 500);
                event.target.value = '';
            },

            removeImage(index) {
                this.previews.splice(index, 1);
                this.compressedFiles.splice(index, 1);
            },

            async submitForm() {
                if (!this.$refs.form.reportValidity()) return;
                this.loading = true;
                const formData = new FormData();

                formData.append('Input.KavlingId', this.$refs.form.querySelector('[name="Input.KavlingId"]').value);
                formData.append('Input.PermitType', this.$refs.form.querySelector('[name="Input.PermitType"]').value);
                formData.append('Input.Description', this.$refs.form.querySelector('[name="Input.Description"]').value);
                
                // Disamakan menggunakan key 'Input.Attachments' sesuai backend
                this.compressedFiles.forEach((file) => {
                    formData.append('Input.Attachments', file, file.name);
                });

                try {
                    const response = await fetch('', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    });

                    const result = await response.json();
                    if (result.success) {
                        showSuccess('Sukses', result.message);
                        setTimeout(() => {
                            location.reload();
                        }, 2000);
                    } else {
                        showError('Gagal', result.message);
                        this.loading = false;
                    }
                } catch (e) {
                    showError('Error', 'Terjadi kesalahan koneksi.');
                    this.loading = false;
                }
            }
        }
    }
</script>