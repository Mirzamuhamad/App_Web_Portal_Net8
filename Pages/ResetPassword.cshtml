@page "/ResetPassword"
@model ResetPasswordModel
@{
    Layout = null; // Atau sesuaikan dengan layout Anda
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
     <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=1, user-scalable=0">
     
    <title>Reset Password</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="stylesheet" href="~/css/custom.css" />
    <script defer src="~/lib/alpinejs@3.x.x/alpinejs.min.js"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600&display=swap" rel="stylesheet">

    <link rel="stylesheet" href="~/css/notyf@3/notyf.min.css">
        <script src="~/lib/notyf/notyf.min.js"></script>

</head>
<body class="bg-gray-100 flex items-center justify-center min-h-screen font-muli">

    <div class="bg-white p-8 rounded-2xl shadow-xl w-full max-w-md">
        <h2 class="text-2xl font-bold text-gray-800 mb-2">Reset Password</h2>
        <p class="text-sm text-gray-500 mb-6">Silakan masukkan password baru Anda.</p>

        <form method="post" class="ajax-reset-form space-y-4">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Token" />

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Password Baru</label>
                <input type="password" asp-for="NewPassword" required
                       class="w-full p-2.5 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition">
                <p class="text-xs text-red-500 mt-1 hidden" data-error-for="NewPassword"></p>
            </div>

            <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Konfirmasi Password</label>
                <input type="password" asp-for="ConfirmPassword" required
                       class="w-full p-2.5 border rounded-lg focus:ring-2 focus:ring-blue-500 outline-none transition">
                <p class="text-xs text-red-500 mt-1 hidden" data-error-for="ConfirmPassword"></p>
            </div>

            <button type="submit" data-submit-btn class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-2.5 rounded-lg transition duration-200 flex items-center justify-center gap-2">
                <span data-btn-text>Update Password</span>
                <span data-spinner class="hidden animate-spin">&#8635;</span>
            </button>
        </form>
    </div>

    <script src="~/js/site.js" asp-append-version="true"></script>

    <script>
        document.querySelector(".ajax-reset-form").addEventListener("submit", async e => {
            e.preventDefault();
            const form = e.target;
            const submitBtn = form.querySelector("[data-submit-btn]");
            const btnText = submitBtn.querySelector("[data-btn-text]");
            const spinner = submitBtn.querySelector("[data-spinner]");

            // LOADING ON
            submitBtn.disabled = true;
            btnText.textContent = "Memproses...";
            spinner.classList.remove("hidden");

            // Reset Error
            form.querySelectorAll("[data-error-for]").forEach(el => el.classList.add("hidden"));

            try {
                const formData = new FormData(form);
                const res = await fetch(window.location.href, {
                    method: "POST",
                    body: formData,
                    headers: {
                        "RequestVerificationToken": document.querySelector('input[name="__RequestVerificationToken"]')?.value
                    }
                });

                const result = await res.json();

                if (!result.success) {
                    if (result.errors) {
                        Object.keys(result.errors).forEach(key => {
                            const errorEl = form.querySelector(`[data-error-for="${key}"]`);
                            if (errorEl) {
                                errorEl.textContent = result.errors[key][0];
                                errorEl.classList.remove("hidden");
                            }
                        });
                    }
                    // Gunakan fungsi showError yang sama dengan Login
                    showError("Gagal", result.message || "Terjadi kesalahan");
                } else {
                    // Gunakan fungsi showSuccess yang sama dengan Login
                    showSuccess("Berhasil", result.message);
                    setTimeout(() => {
                        window.location.href = "/Login";
                    }, 4000);
                }
            } catch (err) {
                showError("Error", "Terjadi kesalahan koneksi");
            } finally {
                // LOADING OFF
                submitBtn.disabled = false;
                btnText.textContent = "Update Password";
                spinner.classList.add("hidden");
            }
        });
    </script>
</body>
</html>