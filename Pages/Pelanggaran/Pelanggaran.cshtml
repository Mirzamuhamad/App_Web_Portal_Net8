@page
@model TestLandingPageNet8.Pages.Pelanggaran.ListModel
@{
    ViewData["Title"] = "Riwayat Pelanggaran";
}

<div x-data="unitDetailLogic()" class="max-w-4x0 mx-auto px-4 sm:px-6 py-6">

    <div class="flex flex-col md:flex-row md:justify-between md:items-center gap-4 mb-6 pb-4 border-b border-slate-100">
        <div>
            <h2 class="text-xl font-bold text-slate-700 tracking-tight">Catatan Pelanggaran Unit</h2>
            <p class="text-xs text-slate-400 mt-1">Daftar ketidaksesuaian tata tertib area kawasan lingkungan Anda.</p>
        </div>

        @* @if(Model.TotalDendaBelumLunas > 0)
        {
            <div class="bg-rose-50 border border-rose-100 px-4 py-2 rounded-2xl flex items-center gap-3">
                <span class="w-2 h-2 rounded-full bg-rose-500 animate-pulse"></span>
                <span class="text-xs font-bold text-rose-600">Total Denda Tempuh: Rp @Model.TotalDendaBelumLunas.ToString("N0",
        new System.Globalization.CultureInfo("id-ID"))</span>
            </div>
        } *@
    </div>

    <div class="space-y-3">
        @if (Model.ViolationItems != null && Model.ViolationItems.Any())
        {
            foreach (var item in Model.ViolationItems)
            {
                var isAlert = item.ViolationStatus != "Lunas";

                <div @@click="openDetail({ 
                    id: '@item.ViolationTransNmbr', 
                    title: '@item.ViolationType', 
                    date: '@item.ViolationDate.ToString("dd MMM yyyy HH:mm")', 
                    status: '@item.ViolationStatus',
                    description: '@item.Description.Replace("'", "\\'")', 
                    fineAmount: @((int)item.FineAmount),
                    images: '@item.ImageUrl'.split(','),
                    photoCount: @item.PhotoCount
                    })"
                    class="block bg-white rounded-2xl border border-slate-200/60 p-4 transition-all duration-200 hover:scale-[1.01] hover:shadow-md hover:border-slate-300 relative overflow-hidden cursor-pointer">

                    <div
                        class="absolute left-0 top-0 bottom-0 w-1.5 @(item.ViolationStatus == "Peringatan" ? "bg-amber-500" : isAlert ? "bg-rose-500" : "bg-emerald-500")">
                    </div>

                    <div class="flex items-start gap-4 pl-2">
                        <div
                            class="w-10 h-10 rounded-xl @(item.ViolationStatus == "Peringatan" ? "bg-amber-50 text-amber-500" : isAlert ? "bg-rose-50 text-rose-500" : "bg-emerald-50 text-emerald-500") flex items-center justify-center flex-shrink-0">
                            <i
                            class="@(item.ViolationStatus == "Peringatan" ? "ri-alert-line" : isAlert ? "ri-error-warning-fill text-xl animate-pulse" : "ri-checkbox-circle-line") text-lg"></i>
                        </div>

                        <div class="flex-grow space-y-1">
                            <div class="flex items-center justify-between gap-2">
                                <span class="text-[10px] font-mono text-slate-400">@item.ViolationTransNmbr</span>
                                <span
                                    class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-md @(item.ViolationStatus == "Peringatan" ? "bg-amber-50 text-amber-600" : isAlert ? "bg-rose-50 text-rose-600" : "bg-emerald-50 text-emerald-600")">
                                    @item.ViolationStatus
                                </span>
                            </div>

                            <h3 class="text-base font-bold text-slate-700 leading-snug">@item.ViolationType</h3>
                            <p class="text-xs text-slate-400 line-clamp-2 leading-relaxed">@item.Description</p>

                            <div class="pt-2 flex justify-between items-end text-[11px] text-slate-400">
                                <span class="flex items-center gap-1 mb-1">
                                    <i class="ri-calendar-line"></i> @item.ViolationDate.ToString("dd MMM yyyy")
                                </span>

                                <div class="relative flex-shrink-0 ml-2">
                                    <div
                                        class="w-12 h-12 rounded-xl border border-slate-200 bg-slate-50 overflow-hidden shadow-sm">
                                        <img src="@item.ThumbnailPath" class="w-full h-full object-cover" alt="Bukti" />
                                    </div>

                                    @if (item.PhotoCount > 1)
                                    {
                                        <span
                                            class="absolute -bottom-1 -right-1 bg-slate-900 text-white text-[9px] font-black w-5 h-5 flex items-center justify-center rounded-full shadow-md z-30 border-2 border-white">
                                            +@(item.PhotoCount - 1)
                                        </span>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div
                class="text-center py-12 text-slate-400 text-sm bg-white rounded-2xl border border-dashed border-slate-200">
                <i class="ri-shield-user-line text-3xl block mb-2 text-slate-300"></i>
                Tidak ada catatan pelanggaran tata tertib.
            </div>
        }
    </div>

    <div x-show="showDetail" x-cloak class="fixed inset-0 z-[100] flex items-center justify-center p-4 overflow-y-auto"
         x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0"
         x-transition:enter-end="opacity-100">

        <div class="fixed inset-0 bg-slate-900/60 backdrop-blur-sm" @@click="showDetail = false"></div>

        <div class="relative bg-white w-full max-w-2xl rounded-3xl shadow-2xl overflow-hidden"
             x-transition:enter="transition ease-out duration-300 transform"
             x-transition:enter-start="opacity-0 scale-95 translate-y-4"
             x-transition:enter-end="opacity-100 scale-100 translate-y-0">

            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <div>
                    <span class="text-[10px] font-mono text-rose-600 uppercase tracking-widest"
                          x-text="selectedViolation.id"></span>
                    <h3 class="text-lg font-bold text-slate-700 block" x-text="selectedViolation.title"></h3>
                </div>
                <button @@click="showDetail = false"
                    class="w-10 h-10 flex items-center justify-center bg-white rounded-xl text-slate-400 hover:text-rose-500 shadow-sm transition">
                    <i class="ri-close-line text-2xl"></i>
                </button>
            </div>

            <div class="p-6 overflow-y-auto max-h-[70vh] no-scrollbar">
                <div class="space-y-6">
                    <div class="grid grid-cols-2 gap-4 pb-6 border-b border-dashed border-slate-200">
                        <div>
                            <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Waktu
                                Kejadian</label>
                                <div class="text-slate-600 font-semibold mt-1 text-sm" x-text="selectedViolation.date">
                                </div>
                            </div>
                            <div class="text-right">
                                <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Status
                                    Sanksi</label>
                                    <div class="mt-1">
                                        <span
                                        :class="selectedViolation.status === 'Peringatan' ? 'bg-amber-50 text-amber-600 border-amber-100' : selectedViolation.status === 'Lunas' ? 'bg-emerald-50 text-emerald-600 border-emerald-100' : 'bg-rose-50 text-rose-600 border-rose-100'"
                                        class="px-3 py-1 text-[10px] font-extrabold rounded-lg border uppercase tracking-wider inline-block"
                                        x-text="selectedViolation.status"></span>
                                    </div>
                                </div>
                            </div>

                            <div>
                                <label
                                    class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-2">Deskripsi /
                                    Kronologi Kejadian</label>
                                    <div
                                        class="bg-slate-50 border border-slate-100 rounded-2xl p-4 text-sm text-slate-600 leading-relaxed">
                                        <i class="ri-chat-quote-line text-rose-300 text-xl block mb-1"></i>
                                        <span x-text="selectedViolation.description"></span>
                                    </div>
                                </div>

                                <div>
                                    <label class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider mb-3">
                                        Lampiran Bukti Lapangan (<span x-text="selectedViolation.photoCount || 0"></span>)
                                    </label>
                                    <div class="grid grid-cols-3 sm:grid-cols-4 gap-3">
                                        <template x-if="selectedViolation.photoCount > 0">
                                            <template x-for="(img, index) in selectedViolation.images" :key="index">
                                                <div @@click="openLightbox(index)"
                                                    class="aspect-square rounded-2xl overflow-hidden border-2 border-slate-100 p-1 bg-white shadow-sm cursor-zoom-in hover:border-rose-500 transition-all group">
                                                    <img :src="img"
                                                         class="w-full h-full object-cover rounded-xl group-hover:scale-110 transition-transform duration-500">
                                                </div>
                                            </template>
                                        </template>
                                        <template x-if="!selectedViolation.photoCount || selectedViolation.photoCount == 0">
                                            <div
                                                class="col-span-full py-10 border-2 border-dashed border-slate-100 rounded-3xl flex flex-col items-center justify-center text-slate-300">
                                                <i class="ri-image-line text-4xl"></i>
                                                <span class="text-xs mt-2 font-medium">Tidak ada lampiran foto bukti</span>
                                            </div>
                                        </template>
                                    </div>
                                </div>

                                <template x-if="selectedViolation.fineAmount > 0">
                                    <div
                                        class="p-4 bg-rose-50/50 rounded-2xl border border-rose-100/70 flex justify-between items-center">
                                        <div>
                                            <span class="block text-[10px] font-bold text-slate-400 uppercase tracking-wider">Total
                                                Sanksi Denda</span>
                                                <span class="text-lg font-black text-rose-600">Rp <span
                                                    x-text="Intl.NumberFormat('id-ID').format(selectedViolation.fineAmount)"></span></span>
                                                </div>
                                                <template x-if="selectedViolation.status !== 'Lunas'">
                                                    <button
                                                        class="px-5 py-2.5 bg-teal-600 hover:bg-teal-700 text-white text-xs rounded-xl font-bold shadow-md shadow-teal-100 transition">Bayar
                                                        Sekarang</button>
                                                    </template>
                                                </div>
                                            </template>
                                        </div>
                                    </div>

                                    <div class="p-4 bg-slate-50 border-t border-slate-100 flex justify-end">
                                        <button @@click="showDetail = false"
                                        class="px-6 py-2.5 bg-slate-600 text-white rounded-xl text-xs font-bold shadow-md transition">Tutup</button>
                                    </div>
                                </div>
                            </div>

                            <div x-show="showLightbox" class="fixed inset-0 z-[200] bg-black/95 flex items-center justify-center p-4" x-cloak
                                @@keydown.window.escape="showLightbox = false">
                                <button @@click="showLightbox = false"
                                    class="absolute top-6 right-6 text-white/70 hover:text-white transition z-[210]"><i
                                    class="ri-close-line text-4xl"></i></button>
                                    <button x-show="selectedViolation.images.length > 1" @@click="prevImg()"
                                            class="absolute left-4 top-1/2 w-12 h-12 bg-white/10 rounded-full text-white hover:bg-white/20"><i
                                        class="ri-arrow-left-s-line text-3xl"></i></button>

                                        <div class="max-w-4xl w-full h-[80vh] flex flex-col items-center justify-center">
                                            <img :src="selectedViolation.images[currentImgIndex]"
                                                 class="max-w-full max-h-full object-contain shadow-2xl rounded-lg">
                                            <div class="mt-4 text-white/50 text-sm font-medium">
                                                <span x-text="currentImgIndex + 1"></span> / <span x-text="selectedViolation.images.length"></span>
                                            </div>
                                        </div>

                                        <button x-show="selectedViolation.images.length > 1" @@click="nextImg()"
                                                class="absolute right-4 top-1/2 w-12 h-12 bg-white/10 rounded-full text-white hover:bg-white/20"><i
                                            class="ri-arrow-right-s-line text-3xl"></i></button>
                                        </div>

                                    </div>

                                    <script>
                                        function unitDetailLogic() {
                                            return {
                                                showDetail: false,
                                                showLightbox: false,
                                                currentImgIndex: 0,
                                                selectedViolation: { id: '', title: '', status: '', description: '', fineAmount: 0, images: [], date: '', photoCount: 0 },

                                                openDetail(data) {
                                                    this.selectedViolation = data;
                                                    this.showDetail = true;
                                                },
                                                openLightbox(index) {
                                                    this.currentImgIndex = index;
                                                    this.showLightbox = true;
                                                },
                                                prevImg() {
                                                    this.currentImgIndex = (this.currentImgIndex > 0) ? this.currentImgIndex - 1 : this.selectedViolation.images.length - 1;
                                                },
                                                nextImg() {
                                                    this.currentImgIndex = (this.currentImgIndex < this.selectedViolation.images.length - 1) ? this.currentImgIndex + 1 : 0;
                                                }
                                            }
                                        }
                                    </script>