@page
@model TestLandingPageNet8.Pages.VendorPortal.IndexModel
@{
    Layout = null; // Menghilangkan navbar merah (EstatePro) dari _Layout utama
}
<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Portal Vendor - @Model.VendorName</title>
    
    <script src="https://cdn.jsdelivr.net/npm/@@alpinejs/persist@@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@@3.x.x/dist/cdn.min.js" defer></script>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css?family=Muli:400,600&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/remixicon@@4.2.0/fonts/remixicon.css" rel="stylesheet" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.28/jspdf.plugin.autotable.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@@11"></script>
    <style>
        [x-cloak] { display: none !important; }

        body {
            font-family: 'Muli', 'Mulish';
        }
    </style>
    <script>
        window.vendorPortalRpoList = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.RpoList, new System.Text.Json.JsonSerializerOptions { PropertyNamingPolicy = System.Text.Json.JsonNamingPolicy.CamelCase }));

        function vendorPortalData() {
            return {
                rpoList: window.vendorPortalRpoList || [],
                selectedRpo: null,
                showModal: false,
                openDetail(rpo) {
                    this.selectedRpo = rpo;
                    this.showModal = true;
                    document.body.style.overflow = 'hidden';
                },
                closeDetail() {
                    this.showModal = false;
                    document.body.style.overflow = 'auto';
                },
                getStatusLabel(status) {
                    if (status === 'D') return 'Deleted';
                    if (status === 'P') return 'Diterima';
                    if (status === 'G') return 'Proses';
                    if (status === 'H') return 'Draft';
                    return status || '-';
                },
                getStatusClass(status) {
                    if (status === 'D') return 'bg-slate-100 text-slate-700 border-slate-200';
                    if (status === 'P') return 'bg-green-50 text-green-700 border-green-200';
                    if (status === 'G' || status === 'H') return 'bg-emerald-50 text-emerald-700 border-emerald-200';
                    return 'bg-blue-50 text-blue-700 border-blue-200';
                },
                formatRupiah(amount) {
                    if (amount === null || amount === undefined) return 'Rp 0';
                    return 'Rp ' + Number(amount).toLocaleString('id-ID', { minimumFractionDigits: 0, maximumFractionDigits: 0 });
                },
                formatDate(dateStr) {
                    if (!dateStr) return '-';
                    const date = new Date(dateStr);
                    return date.toLocaleDateString('id-ID', { day: '2-digit', month: 'long', year: 'numeric' });
                },
                triggerDownload() {
                    window.downloadRpoPdf(this.selectedRpo, this.formatDate, this.formatRupiah);
                }
            };
        }
    </script>
</head>
<body class="bg-slate-50 antialiased">

<div class="max-w-7xl mx-auto p-2 sm:pt-5 pb-30" x-data="vendorPortalData()">

    <div class="relative bg-gradient-to-r from-blue-700 via-indigo-600 to-teal-500 rounded-[2rem] p-6 sm:p-10 text-white shadow-xl overflow-hidden mb-8 mt-4">
        <div class="absolute right-0 top-0 w-64 h-64 bg-white/10 rounded-full blur-3xl -mr-16 -mt-16"></div>
        <div class="absolute left-1/3 bottom-0 w-48 h-48 bg-teal-300/20 rounded-full blur-2xl"></div>
        
        <div class="relative flex flex-col md:flex-row justify-between items-start md:items-center gap-6">
            <div>
                <p class="text-xs sm:text-sm font-bold uppercase tracking-wider text-blue-200">Kawasan Portal Vendor</p>
                <h1 class="text-2xl sm:text-4xl font-extrabold tracking-tight mt-1">@Model.VendorName</h1>
                <div class="flex flex-wrap items-center gap-3 mt-4">
                    <span class="inline-flex items-center gap-1.5 bg-white/15 px-3 py-1 rounded-full text-xs font-semibold backdrop-blur-sm">
                        <i class="ri-hashtag text-teal-300"></i> Kode Vendor: @Model.VendorCode
                    </span>
                    <span class="inline-flex items-center gap-1.5 bg-white/15 px-3 py-1 rounded-full text-xs font-semibold backdrop-blur-sm">
                        <i class="ri-shield-user-line text-teal-300"></i> Peran: VENDOR
                    </span>
                </div>
            </div>
            
            <button type="button" id="btnVendorLogout" class="flex items-center gap-2 bg-white hover:bg-rose-50 text-rose-600 px-6 py-3 rounded-2xl text-xs sm:text-sm font-extrabold shadow-lg transition active:scale-95">
                <i class="ri-logout-box-r-line"></i> Keluar Portal
            </button>
        </div>
    </div>

    @if (Model.IsDemoMode)
    {
        <div class="bg-amber-50 border border-amber-200 rounded-3xl p-5 flex gap-4 items-start text-amber-800 shadow-sm mb-8">
            <div class="w-10 h-10 rounded-2xl bg-amber-100 flex items-center justify-center flex-shrink-0 text-amber-600">
                <i class="ri-information-line text-xl"></i>
            </div>
            <div>
                <h3 class="text-sm font-bold">Mode Demo Aktif</h3>
                <p class="text-xs text-amber-700 mt-1 leading-normal">
                    Vendor dengan kode <strong>@Model.VendorCode</strong> belum memiliki data RPO di database. Kami menampilkan data 10 RPO umum agar Anda dapat melihat tampilan dan menguji detail transaksi.
                </p>
            </div>
        </div>
    }

    <div class="grid grid-cols-2 lg:grid-cols-4 gap-4 mb-8">
        <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm flex items-center justify-between gap-4">
            <div>
                <p class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-slate-400">Total RPO</p>
                <h3 class="text-xl sm:text-3xl font-extrabold text-slate-700 mt-1">@Model.RpoList.Count</h3>
            </div>
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-blue-50 text-blue-600 rounded-2xl flex items-center justify-center flex-shrink-0">
                <i class="ri-file-list-3-line text-xl sm:text-2xl"></i>
            </div>
        </div>
        
        <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm flex items-center justify-between gap-4">
            <div>
                <p class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-slate-400">Diterima</p>
                <h3 class="text-xl sm:text-3xl font-extrabold text-emerald-600 mt-1">
                    @Model.RpoList.Count(x => x.Status == "G" || x.Status == "H")
                </h3>
            </div>
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-emerald-50 text-emerald-600 rounded-2xl flex items-center justify-center flex-shrink-0">
                <i class="ri-checkbox-circle-line text-xl sm:text-2xl"></i>
            </div>
        </div>

        <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm flex items-center justify-between gap-4">
            <div>
                <p class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-slate-400">Diproses</p>
                <h3 class="text-xl sm:text-3xl font-extrabold text-amber-600 mt-1">
                    @Model.RpoList.Count(x => x.Status == "P")
                </h3>
            </div>
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-amber-50 text-amber-600 rounded-2xl flex items-center justify-center flex-shrink-0">
                <i class="ri-time-line text-xl sm:text-2xl"></i>
            </div>
        </div>

        <div class="bg-white rounded-3xl p-5 border border-slate-100 shadow-sm flex items-center justify-between gap-4">
            <div>
                <p class="text-[10px] sm:text-xs font-bold uppercase tracking-wider text-slate-400">Draft</p>
                <h3 class="text-xl sm:text-3xl font-extrabold text-slate-500 mt-1">
                    @Model.RpoList.Count(x => x.Status == "D")
                </h3>
            </div>
            <div class="w-10 h-10 sm:w-12 sm:h-12 bg-slate-50 text-slate-500 rounded-2xl flex items-center justify-center flex-shrink-0">
                <i class="ri-edit-line text-xl sm:text-2xl"></i>
            </div>
        </div>
    </div>

    <div class="bg-white rounded-[2rem] border border-slate-100 shadow-xl shadow-slate-100/50 overflow-hidden">
        <div class="px-6 py-5 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
            <h2 class="text-base sm:text-lg font-bold text-slate-700 flex items-center gap-2">
                <i class="ri-receipt-line text-blue-600"></i> Daftar Penerimaan RPO Terkini
            </h2>
            <span class="text-xs text-slate-400 font-semibold uppercase tracking-wider">Menampilkan 10 RPO Teratas</span>
        </div>

        <div class="hidden md:block overflow-x-auto">
            <table class="w-full text-left border-collapse">
                <thead>
                    <tr class="bg-slate-50/50 text-[10px] sm:text-xs font-bold text-slate-400 uppercase border-b border-slate-100">
                        <th class="py-4 px-6">No. RPO</th>
                        <th class="py-4 px-6">Tanggal</th>
                        <th class="py-4 px-6">No. PO</th>
                        <th class="py-4 px-6">Supplier</th>
                        <th class="py-4 px-6">Total Nilai</th>
                        <th class="py-4 px-6 text-center">Status</th>
                        <th class="py-4 px-6">Keterangan</th>
                        <th class="py-4 px-6 text-center">Aksi</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100 text-sm text-slate-600">
                    <tr x-show="rpoList.length === 0" x-cloak>
                        <td colspan="8" class="py-10 px-6 text-center text-slate-400 font-semibold">
                            Belum ada data RPO untuk vendor ini.
                        </td>
                    </tr>
                    <template x-for="rpo in rpoList" :key="rpo.transNmbr">
                        <tr class="hover:bg-slate-50/40 transition duration-150">
                            <td class="py-4 px-6 font-bold text-blue-600" x-text="rpo.transNmbr"></td>
                            <td class="py-4 px-6" x-text="formatDate(rpo.transDate)"></td>
                            <td class="py-4 px-6 font-semibold text-slate-700" x-text="rpo.poNo"></td>
                            <td class="py-4 px-6" x-text="rpo.suppCode"></td>
                            <td class="py-4 px-6 font-bold text-slate-800" x-text="formatRupiah(rpo.totalForex)"></td>
                            <td class="py-4 px-6 text-center">
                                <span :class="getStatusClass(rpo.status)" class="inline-block px-3 py-1 rounded-xl text-[10px] font-extrabold uppercase tracking-wide border" x-text="getStatusLabel(rpo.status)"></span>
                            </td>
                            <td class="py-4 px-6 max-w-xs truncate" x-text="rpo.remark || '-'"></td>
                            <td class="py-4 px-6 text-center">
                                <button type="button" @@click="openDetail(rpo)" class="inline-flex items-center justify-center gap-1.5 px-4 py-2 border border-slate-200 hover:bg-blue-50 hover:text-blue-600 hover:border-blue-200 text-slate-600 rounded-xl transition font-bold text-xs shadow-sm">
                                    <i class="ri-eye-line text-sm"></i> Detail
                                </button>
                            </td>
                        </tr>
                    </template>
                </tbody>
            </table>
        </div>

        <div class="block md:hidden divide-y divide-slate-100">
            <div x-show="rpoList.length === 0" x-cloak class="p-8 text-center text-slate-400 font-semibold text-sm">
                Belum ada data RPO untuk vendor ini.
            </div>
            <template x-for="rpo in rpoList" :key="rpo.transNmbr">
                <div class="p-4 flex flex-col gap-3">
                    <div class="flex justify-between items-start">
                        <div>
                            <span class="text-[10px] font-bold text-slate-400 uppercase tracking-wide" x-text="formatDate(rpo.transDate)"></span>
                            <h3 class="text-sm font-bold text-blue-600 mt-0.5" x-text="rpo.transNmbr"></h3>
                        </div>
                        <span :class="getStatusClass(rpo.status)" class="inline-block px-2.5 py-0.5 rounded-lg text-[9px] font-extrabold uppercase tracking-wide border" x-text="getStatusLabel(rpo.status)"></span>
                    </div>
                    
                    <div class="h-px bg-slate-100"></div>

                    <div class="grid grid-cols-2 gap-y-2 text-xs">
                        <div>
                            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">No. PO</span>
                            <p class="font-semibold text-slate-700 mt-0.5" x-text="rpo.poNo"></p>
                        </div>
                        <div>
                            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Total Nilai</span>
                            <p class="font-bold text-slate-800 mt-0.5" x-text="formatRupiah(rpo.totalForex)"></p>
                        </div>
                        <div class="col-span-2">
                            <span class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Keterangan</span>
                            <p class="text-slate-600 mt-0.5" x-text="rpo.remark || '-'"></p>
                        </div>
                    </div>
                    
                    <button type="button" @@click="openDetail(rpo)" class="w-full mt-2 py-2.5 border border-slate-200 hover:bg-blue-50 hover:text-blue-600 text-slate-700 rounded-xl transition font-extrabold text-xs shadow-sm flex items-center justify-center gap-1.5">
                        <i class="ri-eye-line"></i> Lihat Detail Transaksi
                    </button>
                </div>
            </template>
        </div>
    </div>

    <div id="modal-rpo-detail" class="fixed inset-0 z-50 flex items-center justify-center px-4 overflow-y-auto" 
         x-show="showModal" x-cloak
         x-transition:enter="transition ease-out duration-300" x-transition:enter-start="opacity-0" x-transition:enter-end="opacity-100">
        
        <div class="fixed inset-0 bg-slate-900/40 backdrop-blur-sm" @@click="closeDetail()"></div>
        <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

        <div class="relative inline-block w-full max-w-4xl bg-white rounded-3xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 border border-slate-100"
             x-show="showModal"
             x-transition:enter="transition ease-out duration-300 transform"
             x-transition:enter-start="opacity-0 scale-95 translate-y-4"
             x-transition:enter-end="opacity-100 scale-100 translate-y-0">
            
            <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                <div class="flex items-center gap-2">
                    <i class="ri-receipt-line text-blue-600 text-xl"></i>
                    <h3 class="text-base font-bold text-slate-800">Rincian Dokumen Penerimaan (RPO)</h3>
                </div>
                <button type="button" @@click="closeDetail()" class="text-slate-400 hover:text-slate-600 rounded-lg p-1 hover:bg-slate-100 transition-all">
                    <i class="ri-close-line text-xl"></i>
                </button>
            </div>

            <template x-if="selectedRpo">
                <div>
                    <div class="p-6 space-y-6">
                        <div class="grid grid-cols-2 md:grid-cols-4 gap-4 bg-slate-50/70 p-5 rounded-2xl text-xs">
                            <div>
                                <span class="text-slate-400 font-bold uppercase tracking-wider block mb-0.5">No. RPO</span>
                                <span class="font-bold text-blue-600 text-sm" x-text="selectedRpo.transNmbr"></span>
                            </div>
                            <div>
                                <span class="text-slate-400 font-bold uppercase tracking-wider block mb-0.5">No. PO Referensi</span>
                                <span class="font-semibold text-slate-700 text-sm" x-text="selectedRpo.poNo"></span>
                            </div>
                            <div>
                                <span class="text-slate-400 font-bold uppercase tracking-wider block mb-0.5">Tanggal Masuk</span>
                                <span class="font-semibold text-slate-700" x-text="formatDate(selectedRpo.transDate)"></span>
                            </div>
                            <div>
                                <span class="text-slate-400 font-bold uppercase tracking-wider block mb-0.5">Status</span>
                                <div class="mt-0.5">
                                    <span :class="getStatusClass(selectedRpo.status)" class="inline-block px-2.5 py-0.5 rounded-lg text-[9px] font-extrabold uppercase tracking-wide border" x-text="getStatusLabel(selectedRpo.status)"></span>
                                </div>
                            </div>
                        </div>

                        <div class="space-y-3">
                            <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider">Item Barang yang Diterima</h4>
                            <div class="border border-slate-100 rounded-2xl overflow-hidden">
                                <table class="w-full text-left text-xs border-collapse">
                                    <thead>
                                        <tr class="bg-slate-50 text-[10px] font-bold text-slate-400 uppercase border-b border-slate-100">
                                            <th class="py-3 px-4">Kode Barang</th>
                                            <th class="py-3 px-4">Keterangan / Deskripsi</th>
                                            <th class="py-3 px-4 text-center">Jumlah</th>
                                            <th class="py-3 px-4 text-center">Satuan</th>
                                            <th class="py-3 px-4 text-right">Harga Satuan</th>
                                            <th class="py-3 px-4 text-right">Total</th>
                                        </tr>
                                    </thead>
                                    <tbody class="divide-y divide-slate-100 text-slate-600">
                                        <template x-for="item in selectedRpo.details" :key="item.productCode + '-' + item.qty">
                                            <tr class="hover:bg-slate-50/20">
                                                <td class="py-3 px-4 font-bold text-slate-700" x-text="item.productCode"></td>
                                                <td class="py-3 px-4" x-text="item.remark || selectedRpo.remark || '-'"></td>
                                                <td class="py-3 px-4 text-center font-semibold text-slate-800" x-text="Number(item.qty).toLocaleString('id-ID')"></td>
                                                <td class="py-3 px-4 text-center uppercase" x-text="item.unit"></td>
                                                <td class="py-3 px-4 text-right font-medium" x-text="formatRupiah(item.priceForex)"></td>
                                                <td class="py-3 px-4 text-right font-bold text-slate-700" x-text="formatRupiah(item.amountForex)"></td>
                                            </tr>
                                        </template>
                                    </tbody>
                                </table>
                            </div>
                        </div>

                        <div class="pt-4 border-t border-slate-100 flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4">
                            <div class="text-xs text-slate-400">
                                <p>Disiapkan oleh: <strong class="text-slate-600" x-text="selectedRpo.userPrep"></strong> pada <span class="text-slate-500" x-text="formatDate(selectedRpo.datePrep)"></span></p>
                            </div>
                            <div class="text-right w-full sm:w-auto">
                                <span class="text-[10px] text-slate-400 font-bold uppercase tracking-wider block">Total Keseluruhan</span>
                                <span class="text-xl sm:text-2xl font-black text-blue-600" x-text="formatRupiah(selectedRpo.totalForex || selectedRpo.details.reduce((sum, d) => sum + d.amountForex, 0))"></span>
                            </div>
                        </div>
                    </div>

                    <div class="px-6 py-4 bg-slate-50/50 border-t border-slate-100 flex flex-col sm:flex-row gap-3 justify-end">
                        <button type="button" @@click="triggerDownload()" class="w-full sm:w-auto px-5 py-3 text-sm font-bold text-white bg-blue-600 hover:bg-blue-700 active:scale-95 transition rounded-xl flex items-center justify-center gap-2 shadow-md shadow-blue-100">
                            <i class="ri-file-download-line text-base"></i> Unduh PDF
                        </button>
                        <button type="button" @@click="closeDetail()" class="w-full sm:w-auto px-5 py-3 text-sm font-semibold text-slate-700 bg-white border border-slate-200 hover:bg-slate-50 active:scale-95 transition rounded-xl flex items-center justify-center">
                            Tutup
                        </button>
                    </div>
                </div>
            </template>
        </div>
    </div>
</div>

<form id="logoutForm" method="post" asp-page-handler="Logout" style="display:none;">
    @Html.AntiForgeryToken()
</form>

<script>
    // Fungsi PDF dipisah global untuk keamanan HTML escaping teks
    window.downloadRpoPdf = function(selectedRpo, formatDateFn, formatRupiahFn) {
        if (!selectedRpo) return;

        const { jsPDF } = window.jspdf;
        const doc = new jsPDF();
        
        doc.setFont('helvetica', 'bold');
        doc.setFontSize(20);
        doc.text('RECEIVING PURCHASE ORDER (RPO)', 14, 20);
        
        doc.setFontSize(10);
        doc.setFont('helvetica', 'normal');
        doc.text('No. RPO: ' + selectedRpo.transNmbr, 14, 30);
        doc.text('No. PO: ' + selectedRpo.poNo, 14, 35);
        doc.text('Tanggal: ' + formatDateFn(selectedRpo.transDate), 14, 40);
        doc.text('Supplier: ' + selectedRpo.suppCode, 14, 45);
        doc.text('Prepared By: ' + selectedRpo.userPrep, 14, 50);
        
        doc.line(14, 53, 196, 53);
        
        const headers = [['Kode Barang', 'Keterangan', 'Jumlah', 'Satuan', 'Harga', 'Total']];
        const data = selectedRpo.details.map(d => [
            d.productCode,
            d.remark || selectedRpo.remark || '-',
            Number(d.qty).toLocaleString('id-ID'),
            d.unit,
            formatRupiahFn(d.priceForex),
            formatRupiahFn(d.amountForex)
        ]);
        
        doc.autoTable({
            head: headers,
            body: data,
            startY: 58,
            theme: 'striped',
            headStyles: { fillColor: [37, 99, 235] }
        });
        
        const finalY = doc.lastAutoTable.finalY + 10;
        doc.setFont('helvetica', 'bold');
        const grandTotal = selectedRpo.totalForex || selectedRpo.details.reduce((sum, d) => sum + d.amountForex, 0);
        doc.text('Total Keseluruhan: ' + formatRupiahFn(grandTotal), 14, finalY);
        
        doc.save('RPO-' + selectedRpo.transNmbr.replace(/\//g, '-') + '.pdf');
    };

    // Handler Logout Alert & Request
    document.getElementById('btnVendorLogout').addEventListener('click', () => {
        Swal.fire({
            title: 'Konfirmasi Keluar',
            text: 'Apakah Anda yakin ingin keluar dari Portal Vendor?',
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: '#ef4444',
            cancelButtonColor: '#6b7280',
            confirmButtonText: 'Ya, Keluar!',
            cancelButtonText: 'Batal'
        }).then(async (result) => {
            if (result.isConfirmed) {
                const form = document.getElementById('logoutForm');
                const formData = new FormData(form);
                try {
                    const response = await fetch('?handler=Logout', {
                        method: 'POST',
                        body: formData,
                        headers: {
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value
                        }
                    });
                    const data = await response.json();
                    if (data.success) {
                        window.location.href = data.redirect;
                    }
                } catch (error) {
                    console.error('Logout error:', error);
                }
            }
        });
    });
</script>

