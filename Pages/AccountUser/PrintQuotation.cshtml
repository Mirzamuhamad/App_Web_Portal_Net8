@page
@model PrintQuotationModel
@{
    Layout = null;
}

<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
<script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf-autotable/3.5.23/jspdf.plugin.autotable.min.js"></script>

<script>
   window.onload = async function () {
    // Ambil data dari C# Model
    const data = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Data));
    console.log("Data diterima:", data); // Cek di F12 jika masih NaN

    const { jsPDF } = window.jspdf;
    const doc = new jsPDF();
    const primaryColor = [13, 148, 136]; // Teal/Tosca sesuai gambar

    // --- 1. HEADER (QUOTATION & NOMOR REQUEST) ---
    doc.setFontSize(22);
    doc.setTextColor(primaryColor[0], primaryColor[1], primaryColor[2]);
    doc.setFont(undefined, 'bold');
    doc.text('QUOTATION', 14, 20);

    doc.setFontSize(10);
    doc.setTextColor(0);
    doc.text('Nomor Request', 196, 20, { align: 'right' });
    doc.setFont(undefined, 'normal');
    doc.text(`${data.TransNmbr || data.transNmbr || '-'}`, 196, 25, { align: 'right' });

    // --- 2. INFORMASI TENANT & TANGGAL ---
    doc.setDrawColor(230);
    doc.line(14, 40, 196, 40); 

    doc.setFontSize(10);
    doc.setFont(undefined, 'bold');
    doc.text('DITUJUKAN KEPADA:', 14, 50);
    doc.setFont(undefined, 'normal');
    doc.text(`${data.NamaTenant || data.namaTenant || 'PT JAYA PURA'}`, 14, 55);
    doc.text(`Unit   : ${data.KavlingName || data.kavlingName || '-'}`, 14, 60);
    doc.text(`No. HP : ${data.NoHp || data.noHp || '-'}`, 14, 65);

    doc.setFont(undefined, 'bold');
    doc.text('TANGGAL PENAWARAN :', 196, 50, { align: 'right' });
    doc.setFont(undefined, 'normal');
    // Menggunakan tanggal dari data atau tanggal hari ini
    const tgl = data.Date || data.date || new Date();
    doc.text(`${new Date(tgl).toLocaleDateString('id-ID', { day: 'numeric', month: 'long', year: 'numeric' })}`, 196, 55, { align: 'right' });


    // --- MASA BERLAKU (Hanya Tanggal) ---
    // Bagian Kanan Bawah: Masa Berlaku
    doc.setFont(undefined, 'bold');
    doc.text('BERLAKU HINGGA :', 196, 62, { align: 'right' }); // Koordinat Y diturunkan ke 62
    doc.setFont(undefined, 'normal');
    const tglExpRaw = data.ValidityDate || data.validityDate || new Date();
    const validityDateStr = new Date(tglExpRaw).toLocaleDateString('id-ID', { 
        day: 'numeric', 
        month: 'long', 
        year: 'numeric' 
    });
    doc.text(validityDateStr, 196, 67, { align: 'right' }); // Koordinat Y diturunkan ke 67

    // --- 3. DESKRIPSI REQUEST (KOTAK BIRU MUDA) ---
    doc.setFillColor(248, 250, 252);
    doc.rect(14, 75, 182, 35, 'F');
    
    doc.setFontSize(9);
    doc.setFont(undefined, 'bold');
    doc.setTextColor(primaryColor[0], primaryColor[1], primaryColor[2]);
    doc.text('DESKRIPSI KELUHAN / REQUEST:', 18, 82);
    
    doc.setFont(undefined, 'normal');
    doc.setTextColor(50);
    const desc = data.Description || data.description || 'Tidak ada deskripsi';
    const splitDescription = doc.splitTextToSize(desc, 174);
    doc.text(splitDescription, 18, 88);

    // --- 4. TABEL UTAMA (HEADER TABEL) ---
    // Perbaikan NaN: Pastikan melakukan parsing ke Number
    const hargaSatuan = Number(data.HargaSatuan || data.hargaSatuan || 0);
    const totalHarga = Number(data.Harga || data.harga || 0);
    const qty = data.Qty || data.qty || 1;

    const tableData = [[
        data.Item || data.item || '', 
        qty, 
        `Rp ${hargaSatuan.toLocaleString('id-ID')}`, 
        `Rp ${totalHarga.toLocaleString('id-ID')}`
    ]];

    doc.autoTable({
        startY: 120,
        head: [['Deskripsi Pekerjaan', 'Qty', 'Harga Satuan', 'Total']],
        body: tableData,
        theme: 'grid',
        headStyles: { 
            fillColor: primaryColor, 
            fontSize: 10, 
            halign: 'center', 
            fontStyle: 'bold',
            textColor: [255, 255, 255] 
        },
        columnStyles: {
            0: { halign: 'left' },
            1: { halign: 'center', cellWidth: 20 },
            2: { halign: 'right', cellWidth: 40 },
            3: { halign: 'right', cellWidth: 40 }
        },
        styles: { fontSize: 9, cellPadding: 5 }
    });

    // --- 5. TABEL DETAIL (MILESTONE) JIKA ADA ---
    // --- 5. TABEL DETAIL (MILESTONE) - BERDASARKAN BILLING MODEL ---
    const billingModel = (data.BillingModel || data.billingModel || "").toUpperCase();

    if (billingModel === "PROJECT") {
        const detailY = doc.lastAutoTable.finalY + 10;
        doc.setFont(undefined, 'bold');
        doc.setTextColor(0);
        doc.text('RINCIAN MILESTONE / DETAIL BIAYA:', 14, detailY - 3);

        const detailRows = data.SubDetails.map((dt, index) => [
            dt.Itemno || dt.itemno || (index + 1),
            dt.MilesStone || dt.milesStone || dt.Description || '-',
            `Rp ${Number(dt.Amount || dt.amount || 0).toLocaleString('id-ID')}`
        ]);

       doc.autoTable({
    startY: detailY,
    head: [['No', 'Milestone', 'Jumlah']],
    body: detailRows,
    theme: 'striped',
    // headStyles mengatur tampilan Label/Header tabel
    headStyles: { 
        fillColor: [220, 220, 220], 
        textColor: 0, 
        halign: 'center' // Membuat semua label header rata tengah
    },
    // columnStyles mengatur tampilan isi data di kolom spesifik
    columnStyles: { 
        0: { halign: 'center', cellWidth: 15 }, // Kolom 'No' rata tengah
        2: { halign: 'right', cellWidth: 40 }  // Kolom 'Jumlah' rata tengah
    },
    styles: {
        fontSize: 9,
        valign: 'middle' // Membuat teks rata tengah secara vertikal
    }
});

 // --- 6. FOOTER & TANDA TANGAN ---
    const footerY = 250;
    doc.setDrawColor(200);
    doc.line(14, footerY, 196, footerY);

    doc.setFontSize(8);
    doc.setFont(undefined, 'normal');
    doc.setTextColor(150);

    // Kalimat Profesional untuk Pajak
    const taxNote = "* Nilai penawaran di atas belum termasuk PPN dan PPh sesuai dengan ketentuan perpajakan yang berlaku.";
    doc.text(taxNote, 14, footerY + 5);

    // Disclaimer Portal
    doc.setTextColor(150); // Abu-abu lebih muda untuk disclaimer
    doc.text('* Ini adalah dokumen penawaran resmi. Silahkan lakukan persetujuan melalui portal.', 14, footerY + 10);
    @* doc.text('* Ini adalah dokumen penawaran resmi. Silahkan lakukan persetujuan melalui portal.', 14, footerY + 5); *@
    //doc.text('* Harga sudah termasuk pajak dan biaya layanan building management.', 14, footerY + 10);
    }

    // --- 6. SAVE & CLOSE ---
    doc.save(`Quotation_${data.TransNmbr || 'Draft'}.pdf`);
    
    // Matikan ini sementara jika ingin melihat console.log
     setTimeout(() => { window.close(); }, 1000); 
};
</script>

<div class="flex items-center justify-center h-screen">
    <p class="text-slate-500 font-sans">Sedang menyiapkan dokumen PDF, mohon tunggu...</p>
</div>