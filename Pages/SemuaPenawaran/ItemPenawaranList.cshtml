@model IReadOnlyList<semuaPenawaranModel.semuaPenawaranItem>
@{
    var search = ViewData["Search"]?.ToString() ?? string.Empty;
    var encodedSearch = System.Net.WebUtility.UrlEncode(search);
    var lastItemId = Model.LastOrDefault()?.Id;
    var nextItemsUrl = $"/SemuaPenawaran/SemuaPenawaran?handler=Items&lastId={lastItemId}&search={encodedSearch}";
}

<div hx-swap-oob="beforeend:#penawaranContainer">
    @foreach (var item in Model)
    {
        <a href="/DetailPenawaran/DetailPenawaran/@item.Id"
           data-penawaran-id="@item.Id"
           class="block rounded-none sm:rounded-2xl overflow-hidden sm:border sm:border-gray-200 sm:shadow-sm hover:shadow-md transition duration-300 hover:-translate-y-1">
            <div class="relative">
                <img src="@item.ImageUrl" class="w-full h-44 sm:h-56 object-cover rounded-md sm:rounded-none" alt="@item.Title" />

                @if (!string.IsNullOrWhiteSpace(item.Tag))
                {
                    <span class="absolute top-3 left-3 bg-white px-3 py-1 rounded-xl text-xs sm:text-sm font-semibold text-gray-700">
                        @item.Tag
                    </span>
                }

                @if (!string.IsNullOrWhiteSpace(item.Price))
                {
                    <span class="absolute bottom-3 right-3 bg-black text-white px-3 sm:px-2 py-2 rounded-xl font-semibold text-xs sm:text-sm">
                        @item.Price
                    </span>
                }
            </div>

            <div class="pt-2 sm:p-2">
                <h3 class="text-sm sm:text-lg font-bold mb-2 text-gray-700">@item.Title</h3>
                <p class="text-gray-600 flex items-center gap-2 text-xs sm:text-sm">
                    <i class="ri-map-pin-line"></i> @item.Location
                </p>
            </div>
        </a>
    }
</div>

@if (Model.Count == semuaPenawaranModel.PageSize)
{
    <div id="penawaranLoadMore"
         data-next-url="@nextItemsUrl">
        <p class="text-center pt-5 text-gray-400">Memuat data berikutnya...</p>
    </div>
}
else
{
    <div id="penawaranLoadMore"></div>
}
