@page
@model semuaPenawaranModel
@{
    if (Request.Headers.ContainsKey("HX-Request"))
    {
        Layout = null;
    }
    else
    {
        Layout = "_Layout";
    }

    ViewData["Title"] = "Semua Penawaran";
    var lastItemId = Model.SemuaPenawaranItems.LastOrDefault()?.Id;
    var encodedSearch = System.Net.WebUtility.UrlEncode(Model.Search ?? string.Empty);
    var nextItemsUrl = $"/SemuaPenawaran/SemuaPenawaran?handler=Items&lastId={lastItemId}&search={encodedSearch}";
}

<div class="max-w-7xl p-2 sm:p-10 mx-auto pb-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 sm:gap-6 items-center">
        <h4 class="text-sm sm:text-2xl font-bold text-gray-700 pb-2 sm:pb-0">
            Jelajahi Semua Penawaran & Promo
        </h4>

        <form method="get" class="w-full flex items-center rounded-full border border-gray-300 overflow-hidden shadow-sm">
            <input type="text"
                   name="search"
                   value="@Model.Search"
                   placeholder="Cari semua penawaran..."
                   class="flex-1 px-3 py-1.5 text-sm outline-none" />

            <button type="submit"
                    class="text-white px-4 py-1.5 rounded-full flex items-center justify-center bg-gray-100 hover:bg-blue-200 transition"
                    title="Cari">
                <img src="~/icons/search.png" class="h-5 w-5" alt="Cari" />
            </button>
        </form>
    </div>

    <div id="penawaranContainer" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-4 mt-8 sm:mt-10">
        @foreach (var item in Model.SemuaPenawaranItems)
        {
            <a href="/DetailPenawaran/DetailPenawaran/@item.Id"
               data-penawaran-id="@item.Id"
               class="block rounded-none sm:rounded-2xl overflow-hidden sm:border sm:border-gray-200 sm:shadow-sm hover:shadow-md transition duration-300 hover:-translate-y-1">
                <div class="relative">
                    <img src="@item.ImageUrl" class="w-full h-44 sm:h-56 object-cover rounded-md sm:rounded-none" alt="@item.Title" />

                    @if (!string.IsNullOrWhiteSpace(item.Tag))
                    {
                        <span class="absolute top-3 left-3 bg-white px-3 py-1 rounded-xl text-xs sm:text-sm font-semibold text-gray-700">
                            @item.Tag
                        </span>
                    }

                    @if (!string.IsNullOrWhiteSpace(item.Price))
                    {
                        <span class="absolute bottom-3 right-3 bg-black text-white px-3 sm:px-2 py-2 rounded-xl font-semibold text-xs sm:text-sm">
                            @item.Price
                        </span>
                    }
                </div>

                <div class="pt-2 sm:p-2">
                    <h3 class="text-sm sm:text-lg font-bold mb-2 text-gray-700">@item.Title</h3>
                    <p class="text-gray-600 flex items-center gap-2 text-xs sm:text-sm">
                        <i class="ri-map-pin-line"></i> @item.Location
                    </p>
                </div>
            </a>
        }
    </div>

    @if (!Model.SemuaPenawaranItems.Any())
    {
        <p class="text-center text-sm text-gray-500 pt-10">Data tidak ditemukan.</p>
    }

    @if (Model.SemuaPenawaranItems.Count == semuaPenawaranModel.PageSize)
    {
        <div id="penawaranLoadMore"
             data-next-url="@nextItemsUrl">
            <p class="text-center pt-5 text-gray-400">Memuat data berikutnya...</p>
        </div>
    }
</div>

<script>
    (function () {
        const stateKey = "__semuaPenawaranInfiniteScroll";
        const state = window[stateKey] || {
            userHasScrolled: false,
            scrollBound: false,
            observer: null,
            loading: false,
            requestedUrls: new Set()
        };
        window[stateKey] = state;
        state.userHasScrolled = false;
        state.loading = false;
        state.requestedUrls = new Set();

        function removeDuplicateCards() {
            const seen = new Set();
            document.querySelectorAll("#penawaranContainer [data-penawaran-id]").forEach(function (card) {
                const id = card.dataset.penawaranId;
                if (seen.has(id)) {
                    card.remove();
                    return;
                }

                seen.add(id);
            });
        }

        function loadNext(trigger) {
            const url = trigger.dataset.nextUrl;
            if (!url || state.loading || state.requestedUrls.has(url) || !window.htmx) {
                return;
            }

            state.loading = true;
            state.requestedUrls.add(url);
            state.userHasScrolled = false;
            htmx.ajax("GET", url, {
                target: "#penawaranLoadMore",
                swap: "outerHTML"
            });
        }

        function isVisible(trigger) {
            const rect = trigger.getBoundingClientRect();
            return rect.top <= window.innerHeight + 120 && rect.bottom >= 0;
        }

        function loadIfReady() {
            const trigger = document.getElementById("penawaranLoadMore");
            if (!state.userHasScrolled || !trigger || !trigger.dataset.nextUrl || !isVisible(trigger)) {
                return;
            }

            if (state.observer) {
                state.observer.disconnect();
            }

            loadNext(trigger);
        }

        function setupObserver() {
            if (state.observer) {
                state.observer.disconnect();
            }

            const trigger = document.getElementById("penawaranLoadMore");
            if (!trigger || !trigger.dataset.nextUrl) {
                return;
            }

            state.observer = new IntersectionObserver(function (entries) {
                if (!state.userHasScrolled) {
                    return;
                }

                if (entries.some(entry => entry.isIntersecting)) {
                    state.observer.disconnect();
                    loadNext(trigger);
                }
            }, { rootMargin: "120px" });

            state.observer.observe(trigger);
            loadIfReady();
        }

        if (!state.scrollBound) {
            window.addEventListener("scroll", function () {
                state.userHasScrolled = true;
                loadIfReady();
            }, { passive: true });
            state.scrollBound = true;
        }

        if (state.afterSettleHandler) {
            document.body.removeEventListener("htmx:afterSettle", state.afterSettleHandler);
        }

        state.afterSettleHandler = function () {
            state.loading = false;
            removeDuplicateCards();
            setupObserver();
        };
        document.body.addEventListener("htmx:afterSettle", state.afterSettleHandler);
        removeDuplicateCards();
        setupObserver();
    })();
</script>
