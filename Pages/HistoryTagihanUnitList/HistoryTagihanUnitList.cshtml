@page
@model Pages.HistoryTagihanUnitList.HistoryTagihanUnitListModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "History Tagihan Lunas";
}

<div class="min-h-screen bg-slate-50 pb-20">
    <div class="bg-white border-b sticky top-0 z-30 px-2 sm:px-6 py-3 shadow-sm">
        <div class="mx-auto flex items-center justify-between gap-4">
            <div class="flex items-center gap-4 min-w-0">
                <a href="/TagihanUnitList/TagihanUnitList"
                    class="w-10 h-10 flex items-center justify-center bg-slate-100 rounded-2xl text-slate-500 hover:bg-emerald-50 hover:text-emerald-600 transition">
                    <i class="ri-arrow-left-line text-xl"></i>
                </a>
                <div class="min-w-0">
                    <h1 class="text-base sm:text-lg font-bold text-slate-700 truncate">History Tagihan Lunas</h1>
                    <p class="text-[10px] sm:text-xs text-slate-400 uppercase tracking-widest font-semibold">Arsip pembayaran unit</p>
                </div>
            </div>

            <span class="hidden sm:inline-flex items-center gap-2 px-4 py-2 rounded-xl bg-emerald-50 text-emerald-600 text-xs font-bold border border-emerald-100">
                <i class="ri-checkbox-circle-fill text-base"></i>
                Tagihan Sudah Lunas
            </span>
        </div>
    </div>

    <div class="grid grid-cols-1 gap-4 pt-5 mx-auto px-2 sm:px-6">
        @if (Model.UnitItems.Any())
        {
            @foreach (var item in Model.UnitItems)
            {
                <a asp-page="/HistoryTagihanUnitList/HistoryTagihanUnitDetailPage/HistoryTagihanUnitDetailPage"
                    asp-route-id="@item.KavlingId"
                    class="block transform hover:scale-[1.002] transition duration-200">

                    <div class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-emerald-100 p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-4 relative overflow-hidden">
                        <div class="absolute inset-y-0 right-0 w-24 bg-emerald-50/60"></div>

                        <div class="flex items-start gap-3 flex-1 min-w-0 relative">
                            <div class="w-1.5 h-12 rounded-full flex-shrink-0 mt-0.5 bg-emerald-500"></div>

                            <div class="flex-1 min-w-0">
                                <span class="text-[10px] sm:text-xs font-bold text-emerald-600 uppercase tracking-wider block mb-0.5">History Tagihan Kavling</span>
                                <h3 class="text-base sm:text-lg font-bold truncate text-slate-700">
                                    @item.KavlingCode
                                </h3>

                                <div class="mt-2 flex flex-wrap items-center gap-x-4 gap-y-1 text-xs text-slate-400">
                                    <span class="flex items-center gap-1">
                                        <i class="fa-solid fa-ruler-combined text-[10px]"></i> Luas: @item.Luas.ToString("N2", new System.Globalization.CultureInfo("id-ID")) m²
                                    </span>
                                    <span class="text-emerald-600 font-medium flex items-center gap-1">
                                        <i class="fa-solid fa-circle-check text-[10px]"></i> @item.PaidInvoiceCount invoice lunas
                                    </span>
                                </div>
                            </div>
                        </div>

                        <div class="border border-emerald-200 rounded-xl p-3 flex items-center justify-between gap-4 w-full sm:w-[280px] flex-shrink-0 bg-emerald-50/40 text-gray-700 relative">
                            <div class="flex items-center justify-center w-8 h-8 rounded-lg flex-shrink-0 bg-emerald-100 text-emerald-600">
                                <i class="fa-solid fa-receipt text-sm"></i>
                            </div>

                            <div class="text-right flex-1 min-w-0">
                                <p class="text-[9px] uppercase tracking-wider text-emerald-600 font-semibold leading-none mb-1.5">Total Tagihan Lunas</p>
                                <h2 class="text-base sm:text-lg font-bold tracking-tight text-slate-700 whitespace-nowrap">
                                    <span class="text-xs font-semibold text-emerald-500 mr-0.5">Rp</span>@item.TotalPaidAmount.ToString("N0", new System.Globalization.CultureInfo("id-ID"))
                                </h2>
                            </div>
                        </div>
                    </div>
                </a>
            }
        }
        else
        {
            <div class="bg-white rounded-2xl border border-dashed border-slate-200 p-10 text-center shadow-sm">
                <i class="ri-inbox-archive-line text-5xl text-slate-200"></i>
                <h2 class="mt-3 text-base font-bold text-slate-600">Belum ada history tagihan lunas</h2>
                <p class="mt-1 text-xs text-slate-400">Tagihan yang sudah berstatus lunas akan tampil di halaman ini.</p>
            </div>
        }
    </div>
</div>
