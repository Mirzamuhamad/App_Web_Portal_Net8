@page
@model TestLandingPageNet8.Pages.HistoryTagihanUnitList.HistoryTagihanUnitDetailPage.HistoryTagihanUnitDetailPageModel
@{
    Layout = "_Layout";
    ViewData["Title"] = "History Tagihan Lunas";
    var culture = new System.Globalization.CultureInfo("id-ID");
    var invoiceGrouped = Model.UnitDetailTagihan
        .GroupBy(x => x.TransNmbr)
        .ToList();
}

@functions {
    private static string ToBase64Url(string value)
    {
        if (string.IsNullOrWhiteSpace(value))
        {
            return string.Empty;
        }

        return System.Convert.ToBase64String(System.Text.Encoding.UTF8.GetBytes(value))
            .TrimEnd('=')
            .Replace('+', '-')
            .Replace('/', '_');
    }
}

<div class="min-h-screen bg-slate-50 pb-20">
    <div class="bg-white border-b sticky top-0 z-30 px-2 sm:px-6 py-3 shadow-sm">
        <div class="mx-auto flex items-center justify-between gap-4">
            <div class="flex items-center gap-4 min-w-0">
                <a href="/HistoryTagihanUnitList/HistoryTagihanUnitList"
                    class="w-10 h-10 flex items-center justify-center bg-slate-100 rounded-2xl text-slate-500 hover:bg-emerald-50 hover:text-emerald-600 transition">
                    <i class="ri-arrow-left-line text-xl"></i>
                </a>
                <div class="min-w-0">
                    <h1 class="text-lg font-bold text-slate-700 truncate">@Model.Unit.KavlingCode</h1>
                    <span class="flex items-center gap-1 text-slate-400 text-[12px] sm:text-xs">
                        <i class="fa-solid fa-ruler-combined"></i> @Model.Unit.Luas.ToString("N2", culture) m²
                    </span>
                </div>
            </div>

            <div class="hidden sm:flex items-center gap-2 px-4 py-2 rounded-xl bg-emerald-50 text-emerald-600 text-xs font-bold border border-emerald-100">
                <i class="ri-checkbox-circle-fill text-base"></i>
                History Lunas
            </div>
        </div>
    </div>

    <div class="mx-auto px-2 sm:px-6 mt-4">
        <div class="bg-white rounded-2xl border border-emerald-100 shadow-sm p-5 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
            <div>
                <p class="text-[10px] text-emerald-600 uppercase tracking-widest font-bold">Ringkasan Pembayaran</p>
                <h2 class="text-base sm:text-lg font-bold text-slate-700">@invoiceGrouped.Count invoice sudah lunas</h2>
            </div>
            <div class="text-left sm:text-right">
                <p class="text-[10px] text-slate-400 uppercase tracking-widest font-semibold">Total History Lunas</p>
                <div class="text-xl sm:text-2xl font-bold text-slate-800">
                    <span class="text-sm text-emerald-500">Rp</span> @Model.TotalSemuaTagihan.ToString("N0", culture)
                </div>
            </div>
        </div>
    </div>

    @if (invoiceGrouped.Any())
    {
        for (var index = 0; index < invoiceGrouped.Count; index++)
        {
            var invoice = invoiceGrouped[index];
            var headerInvoice = invoice.First();
            var totalInvoiceIni = invoice.Sum(x => x.AmountPerKavling);
            var modalId = $"history-billing-{index}";
            var invoiceKey = ToBase64Url(headerInvoice.TransNmbr);
            var kwitansiFileKey = ToBase64Url(headerInvoice.FileKwitansi);
            var fakturPajakFileKey = ToBase64Url(headerInvoice.FileFakturPajak);
            var downloadBasePath = "/HistoryTagihanUnitList/HistoryTagihanUnitDetailPage/HistoryDownload";
            var kwitansiDownloadUrl = $"{downloadBasePath}?fileKey={kwitansiFileKey}&documentType=kwitansi&invoiceKey={invoiceKey}";
            var fakturPajakDownloadUrl = $"{downloadBasePath}?fileKey={fakturPajakFileKey}&documentType=faktur-pajak&invoiceKey={invoiceKey}";

            <div class="mx-auto px-2 sm:px-6 mt-3 sm:mt-5">
                <section aria-labelledby="billing-title-@modalId"
                    class="bg-white rounded-2xl shadow-xl shadow-slate-200/50 border border-emerald-100 p-6 md:p-8">

                    <div class="flex flex-col sm:flex-row justify-between items-start gap-4 mb-3">
                        <div class="space-y-0">
                            <div class="flex items-center gap-2">
                                <div class="w-2 h-6 bg-emerald-500 rounded-full"></div>
                                <h2 class="text-xs sm:text-sm text-slate-500 font-bold uppercase tracking-widest" id="billing-title-@modalId">
                                    No Tagihan Lunas
                                </h2>
                            </div>
                            <div class="text-base sm:text-lg font-bold text-emerald-600 tracking-wider pl-4">
                                @(string.IsNullOrEmpty(headerInvoice.TransNmbr) ? "-" : headerInvoice.TransNmbr)
                            </div>
                        </div>

                        <div class="text-left sm:text-right">
                            <p class="text-[10px] text-slate-400 uppercase tracking-[0.2em] mb-1 font-semibold">Total Dibayar</p>
                            <div class="text-xl sm:text-3xl text-slate-800 font-bold tracking-tight">
                                <span class="text-xs sm:text-lg font-bold text-emerald-500 mr-0.5">Rp </span>@totalInvoiceIni.ToString("N0", culture)
                            </div>
                        </div>
                    </div>

                    <div class="h-px w-full mb-4 border-t border-dashed border-slate-200"></div>

                    <div class="flex flex-col md:flex-row md:items-end justify-between gap-6 w-full">
                        <div class="flex flex-wrap items-end flex-1 gap-6 sm:gap-12">
                            <div>
                                <p class="text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 font-semibold">Periode / Jatuh Tempo</p>
                                <div class="flex items-center gap-1.5 text-slate-600">
                                    <i class="ri-calendar-event-line text-emerald-500 text-sm"></i>
                                    <p class="font-bold text-xs sm:text-sm">
                                        @(headerInvoice.DueDate.HasValue ? headerInvoice.DueDate.Value.ToString("dd MMMM yyyy", culture) : "-")
                                    </p>
                                </div>
                            </div>

                            <div>
                                <p class="text-[10px] text-slate-400 uppercase tracking-widest mb-1.5 font-semibold">Status Pembayaran</p>
                                <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-xl bg-emerald-50 text-emerald-600 text-[10px] font-extrabold border border-emerald-100 uppercase tracking-wider">
                                    <i class="ri-checkbox-circle-fill text-xs"></i>
                                    Lunas
                                </span>
                            </div>
                        </div>

                        <div class="w-full md:w-auto flex flex-col sm:flex-row gap-2 justify-end">
                            <a href="@kwitansiDownloadUrl"
                                class="border border-emerald-600 text-emerald-600 hover:bg-emerald-50 px-5 py-2 rounded-xl transition-all w-full md:w-auto text-center active:scale-95 flex items-center justify-center gap-2 text-xs font-bold shadow-sm">
                                <i class="ri-receipt-line text-base"></i>
                                Download Kwitansi
                            </a>

                            <a href="@fakturPajakDownloadUrl"
                                class="border border-sky-600 text-sky-600 hover:bg-sky-50 px-5 py-2 rounded-xl transition-all w-full md:w-auto text-center active:scale-95 flex items-center justify-center gap-2 text-xs font-bold shadow-sm">
                                <i class="ri-file-shield-2-line text-base"></i>
                                Download Faktur Pajak
                            </a>
                            <button type="button" onclick="openBillingModal('@modalId')"
                                class="border border-slate-200 hover:bg-slate-50 text-slate-700 px-5 py-2 rounded-xl transition-all w-full md:w-auto text-center active:scale-95 flex items-center justify-center gap-2 text-xs font-semibold shadow-sm">
                                <i class="ri-file-list-3-line text-base text-slate-400"></i>
                                Detail Tagihan
                            </button>
                        </div>
                    </div>
                </section>
            </div>

            <div id="modal-billing-@modalId" class="fixed inset-0 z-50 hidden overflow-y-auto" aria-labelledby="modal-title-@modalId" role="dialog" aria-modal="true">
                <div class="flex items-center justify-center min-h-screen px-4 pt-4 pb-20 text-center sm:block sm:p-0">
                    <div class="fixed inset-0 transition-opacity bg-slate-900/40 backdrop-blur-sm" onclick="closeBillingModal('@modalId')"></div>
                    <span class="hidden sm:inline-block sm:align-middle sm:h-screen" aria-hidden="true">&#8203;</span>

                    <div class="inline-block align-bottom bg-white rounded-3xl text-left overflow-hidden shadow-2xl transform transition-all sm:my-8 sm:align-middle sm:max-w-lg sm:w-full border border-slate-100">
                        <div class="px-6 py-4 border-b border-slate-100 flex justify-between items-center bg-slate-50/50">
                            <div class="flex items-center gap-2">
                                <i class="ri-receipt-line text-emerald-500 text-xl"></i>
                                <h3 class="text-base font-bold text-slate-800" id="modal-title-@modalId">Rincian Tagihan Lunas</h3>
                            </div>
                            <button type="button" onclick="closeBillingModal('@modalId')" class="text-slate-400 hover:text-slate-600 rounded-lg p-1 hover:bg-slate-100 transition-all">
                                <i class="ri-close-line text-xl"></i>
                            </button>
                        </div>

                        <div class="p-6 space-y-4">
                            <div class="grid grid-cols-2 gap-4 bg-emerald-50 p-4 rounded-xl text-xs">
                                <div>
                                    <p class="text-emerald-600 uppercase tracking-wider mb-0.5 font-semibold">No Invoice</p>
                                    <p class="font-bold text-slate-700">@headerInvoice.TransNmbr</p>
                                </div>
                                <div class="text-right">
                                    <p class="text-emerald-600 uppercase tracking-wider mb-0.5 font-semibold">Status</p>
                                    <p class="font-bold text-emerald-600">Lunas</p>
                                </div>
                            </div>

                            <div class="space-y-3 max-h-60 overflow-y-auto pr-1">
                                <h4 class="text-xs font-bold text-slate-400 uppercase tracking-wider mb-1">Daftar Komponen Biaya</h4>

                                @foreach (var item in invoice)
                                {
                                    <div class="border border-slate-100 bg-slate-50/30 rounded-xl p-3 flex justify-between items-start gap-4">
                                        <div class="space-y-0.5">
                                            <span class="inline-block text-[10px] bg-emerald-50 text-emerald-700 px-2 py-0.5 rounded-md font-bold uppercase tracking-wide">
                                                @item.CommercialItem
                                            </span>
                                            <p class="text-xs text-slate-600 leading-normal pt-1">@item.CommercialDesc</p>
                                        </div>
                                        <div class="text-right whitespace-nowrap">
                                            <p class="text-xs font-bold text-slate-800">
                                                Rp @item.AmountPerKavling.ToString("N0", culture)
                                            </p>
                                        </div>
                                    </div>
                                }
                            </div>

                            <div class="space-y-2 pt-2 border-t border-slate-100">
                                <div class="flex justify-between items-center font-bold text-slate-800 text-base pt-2">
                                    <span>Total Dibayar</span>
                                    <span class="text-emerald-600">Rp @totalInvoiceIni.ToString("N0", culture)</span>
                                </div>
                            </div>
                        </div>

                        <div class="px-6 py-4 bg-slate-50/50 border-t border-slate-100 flex justify-end">
                            <button type="button" onclick="closeBillingModal('@modalId')" class="w-full sm:w-auto px-5 py-2 text-sm font-medium text-slate-700 bg-white border border-slate-200 rounded-xl hover:bg-slate-50 active:scale-95 transition-all shadow-sm">
                                Tutup Detail
                            </button>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="mx-auto px-2 sm:px-6 mt-4">
            <div class="bg-white rounded-2xl border border-dashed border-slate-200 p-10 text-center shadow-sm">
                <i class="ri-inbox-archive-line text-5xl text-slate-200"></i>
                <h2 class="mt-3 text-base font-bold text-slate-600">Belum ada tagihan lunas untuk unit ini</h2>
                <p class="mt-1 text-xs text-slate-400">Invoice yang sudah lunas akan muncul sebagai history di sini.</p>
            </div>
        </div>
    }
</div>

<script>
    function openBillingModal(modalKey) {
        const modal = document.getElementById('modal-billing-' + modalKey);
        if (modal) {
            modal.classList.remove('hidden');
            document.body.style.overflow = 'hidden';
        }
    }

    function closeBillingModal(modalKey) {
        const modal = document.getElementById('modal-billing-' + modalKey);
        if (modal) {
            modal.classList.add('hidden');
            document.body.style.overflow = 'auto';
        }
    }


</script>
