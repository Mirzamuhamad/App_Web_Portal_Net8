@page
@model TestLandingPageNet8.Pages.HistoryTagihanUnitList.HistoryTagihanUnitDetailPage.HistoryTagihanUnitInvoicePrintModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>@Model.DocumentTitle - @Model.InvoiceHeader.TransNmbr</title>
    <!-- Library html2pdf.js untuk auto-download -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    
    <style>
        @@media print {
            body { margin: 0; padding: 0; }
        }
        body {
            font-family: Arial, Helvetica, sans-serif;
            color: #4b4b4b;
            line-height: 1.3;
            font-size: 11pt;
            margin: 0;
            padding: 0;
            background-color: #fff;
        }
        /* Pembungkus luar presisi ukuran A4 asli */
        .invoice-container {
            width: 175mm;
            margin: 0 auto;
            padding: 15mm 5mm;
        }
        .header-table {
            width: 100%;
            border-collapse: collapse;
            margin-bottom: 5px;
        }
        .logo-area {
            text-align: center;
            font-size: 18pt;
            font-weight: bold;
            color: #2c3e50;
            vertical-align: middle;
            line-height: 1.2;
        }
        .subtitle-company {
            font-size: 12pt;
            font-weight: bold;
            letter-spacing: 1px;
            margin-top: 3px;
        }
        .address-company {
            font-size: 9.5pt;
            font-weight: normal;
            color: #4b4b4b;
            margin-top: 5px;
        }
        .divider-line {
            border-top: 2px solid #4b4b4b;
            border-bottom: 1px solid #4b4b4b;
            height: 2px;
            margin-bottom: 15px;
        }
        .title-section {
            text-align: center;
            margin-bottom: 25px;
        }
        .invoice-title {
            font-size: 13pt;
            font-weight: bold;
            text-decoration: underline;
            margin: 0;
            letter-spacing: 0.5px;
        }
        .invoice-number {
            font-size: 11pt;
            margin-top: 3px;
        }
        .meta-text-block {
            margin-bottom: 15px;
        }
        
        /* CSS Tabel Sesuai Gambar Baru */
        .item-table {
            width: 100%;
            border-collapse: collapse;
            margin-top: 15px;
            margin-bottom: 15px;
        }
        .item-table th {
            border: 1px solid #4b4b4b;
            padding: 8px;
            font-size: 11pt;
            font-weight: normal;
            text-align: center;
        }
        .item-table td {
            border: 1px solid #4b4b4b;
            padding: 8px;
            font-size: 11pt;
            vertical-align: top;
        }
        .text-right {
            text-align: right;
        }
        .summary-label {
            text-align: right;
            border-right: none !important;
        }
        .summary-value {
            border-left: none !important;
        }

        .footer-info-section {
            margin-top: 20px;
            font-size: 10pt;
        }
        .info-list-table {
            margin-top: 15px;
            border-collapse: collapse;
        }
        .info-list-table td {
            padding: 2px 0;
            vertical-align: top;
        }
        .note-block {
            margin-top: 20px;
            font-size: 10pt;
        }
        
        /* Loading Overlay */
        #loading-overlay {
            position: fixed; top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(255,255,255,0.95); z-index: 9999;
            display: flex; flex-direction: column; align-items: center; justify-content: center;
            font-family: sans-serif; font-size: 14px; color: #333;
        }
        .spinner {
            border: 4px solid #f3f3f3; border-top: 4px solid #4b4b4b;
            border-radius: 50%; width: 35px; height: 35px; animation: spin 1s linear infinite;
            margin-bottom: 10px;
        }
        @@keyframes spin { 0% { transform: rotate(0deg); } 100% { transform: rotate(360deg); } }
    </style>
</head>
<body>

    <div id="loading-overlay">
        <div class="spinner"></div>
        <div>Mengekspor @Model.DocumentTitle ke PDF...</div>
    </div>

    <div id="invoice-pdf-content" class="invoice-container">

       <!-- Kop Surat Perusahaan -->
<table class="header-table" style="width: 100%;">
    <tr>
        <td style="width: 15%; text-align: left; vertical-align: middle;">
            <!-- Memasukkan logo di dalam kotak 70x70px -->
            <div style="width: 100px; height: 100px;">
                <img src="~/image/Logo_CV_AMT.png" alt="Logo CV AMT" style="width: 100%; height: 100%; object-fit: contain;" />
            </div>
        </td>
        <td class="logo-area" style="vertical-align: middle;">
            <div class="title">@Model.InvoiceHeader.CompanyName</div>
            <div class="subtitle-company">KAWASAN INDUSTRI SUMBER REJEKI</div>
            <div class="address-company">
                @Model.InvoiceHeader.Address
            </div>
        </td>
    </tr>
</table>
        
        <!-- Garis Pembatas Kop -->
        <div class="divider-line"></div>

        <!-- Judul Invoice -->
        <div class="title-section">
            <h1 class="invoice-title">@Model.DocumentTitle</h1>
            <div class="invoice-number">Nomor : @Model.InvoiceHeader.TransNmbr</div>
        </div>

        <!-- Tujuan & Periode Atas -->
        <div class="meta-text-block">
            Kepada Yth,<br>
            <strong>Bapak/ibu Pimpinan</strong><br>
            <strong>Kavling @Model.InvoiceHeader.KavlingCode</strong>
        </div>

        <div class="meta-text-block" style="margin-top: 20px;">
            <table style="border-collapse: collapse;">
                <tr>
                    <td style="width: 90px;"><strong>Periode</strong></td>
                    <td style="width: 20px;">:</td>
                    <td><strong>@(Model.InvoiceHeader.DueDate.HasValue ? Model.InvoiceHeader.DueDate.Value.ToString("MMMM yyyy", new System.Globalization.CultureInfo("id-ID")) : "-")</strong></td>               </tr>
            </table>
        </div>

        <div class="meta-text-block" style="margin-top: 25px;">
            Dengan hormat,<br><br>
            Berikut kami sampaikan rincian tagihan yang sudah lunas untuk Kavling @Model.InvoiceHeader.KavlingCode dengan ketentuan sebagai berikut:
        </div>

        <!-- TABEL BARU: 2 KOLOM (Commercial Item & Subtotal) -->
       <!-- TABEL BARU: 2 KOLOM (Commercial Item & Subtotal) -->
        <table class="item-table">
            <thead>
                <tr>
                    <th style="width: 70%;">Commercial Item</th>
                    <th style="width: 30%;">Subtotal</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.InvoiceItems)
                {
                    <tr style="vertical-align: top;">
                        <!-- Kolom Kiri: Judul & Deskripsi Langsung Menyatu -->
                        <td style="padding: 8px;">
                            <strong>@item.CommercialItem</strong><br />
                            <span style="white-space: pre-line; color: #4b4b4b; font-size: 10.5pt; line-height: 1.2;">@item.DeskripsiItemCommercial</span>
                        </td>
                        <!-- Kolom Kanan: Nominal Rupiah -->
                        <td class="text-right" style="padding: 8px;">
                            <span style="float: left;">Rp</span>
                            <span>@item.NettoForex.ToString("N0", new System.Globalization.CultureInfo("id-ID"))</span>
                        </td>
                    </tr>
                }
                                
                <!-- Total : -->
                <tr>
                    <td class="summary-label" style="font-weight: bold; padding: 8px;">JUMLAH :</td>
                    <td class="text-right summary-value" style="font-weight: bold; padding: 8px;">
                        <span style="float: left;">Rp</span>
                        <span>@Model.InvoiceHeader.BaseForex.ToString("N0", new System.Globalization.CultureInfo("id-ID"))</span>
                    </td>
                </tr>
                <!-- Ppn : -->
                <tr>
                    <td class="summary-label" style="font-weight: bold; padding: 8px;">PPN @Model.InvoiceHeader.PPn.ToString("N0", new System.Globalization.CultureInfo("id-ID"))%:</td>
                    <td class="text-right summary-value" style="font-weight: bold; padding: 8px;">
                        <span style="float: left;">Rp</span>
                        <span>@Model.InvoiceHeader.PPnForex.ToString("N0", new System.Globalization.CultureInfo("id-ID"))</span>
                    </td>
                </tr>
                <!-- Grand Total : -->
                <tr>
                    <td class="summary-label" style="font-weight: bold; padding: 8px;">TOTAL :</td>
                    <td class="text-right summary-value" style="font-weight: bold; padding: 8px; background-color: #f9f9f9;">
                        <span style="float: left;">Rp</span>
                        <span>@Model.InvoiceHeader.TotalForex.ToString("N0", new System.Globalization.CultureInfo("id-ID"))</span>
                    </td>
                </tr>
            </tbody>
        </table>

        <!-- Keterangan & Detail Pembayaran -->
        <div class="footer-info-section">
            <div>- &nbsp; Untuk luas lahan &le; 2.100 M2 akan dikenakan biaya sebesar Rp. 500,000</div>
            
            <table class="info-list-table">
                <tr>
                    <td style="width: 15px;">-</td>
                    <td style="width: 160px;">Periode IPL</td>
                    <td style="width: 20px;">:</td>
                     <td>@(Model.InvoiceHeader.DueDate.HasValue ? Model.InvoiceHeader.DueDate.Value.ToString("MMMM yyyy", new System.Globalization.CultureInfo("id-ID")) : "-")</td>               </tr>

                </tr>
                <tr>
                    <td>-</td>
                    <td>Tanggal Pembayaran</td>
                    <td>:</td>
                     <td>@(Model.InvoiceHeader.DueDate.HasValue ? Model.InvoiceHeader.DueDate.Value.ToString(" dd MMMM yyyy", new System.Globalization.CultureInfo("id-ID")) : "-")</td>               </tr>
                </tr>
                <tr>
                    <td>-</td>
                    <td>Rekening Pembayaran</td>
                    <td></td>
                    <td></td>
                </tr>
                <tr>
                    <td></td>
                    <td style="padding-left: 15px;">Nama</td>
                    <td>:</td>
                    <td>@Model.InvoiceHeader.CompanyName</td>
                </tr>
                <tr>
                    <td></td>
                    <td style="padding-left: 15px;">Nomor Virtual Account</td>
                    <td>:</td>
                    <td>@Model.InvoiceHeader.Rekening</td>
                </tr>
                <tr>
                    <td></td>
                    <td style="padding-left: 15px;">Bank</td>
                    <td>:</td>
                    <td>@Model.InvoiceHeader.Bank</td>
                </tr>
            </table>
        </div>

        <div class="note-block">
           Note :<br>
            <span style="padding-left: 10px; font-weight: regular; font-style: italic;">
                " Pembayaran hanya bisa dilakukan dengan Internet Mobile Banking Mandiri atau Datang ke Teller Bank Mandiri "
            </span>
        </div>
    <!-- Footer Info Download -->
<div style="text-align: right; font-size: 8pt; color: #888888; margin-top: 20px; font-style: italic;">
    Diunduh pada: @DateTime.Now.ToString("dd MMMM yyyy HH:mm", new System.Globalization.CultureInfo("id-ID")) WIB
</div>

    </div>

    <script>
        window.onload = function () {
            const rawInvNo = "@Model.InvoiceHeader.TransNmbr";
            const cleanInvNo = rawInvNo.replace(/[\/\\*?:"<>|]/g, "-");
            
            const element = document.getElementById('invoice-pdf-content');
            
            const opt = {
                margin:       [0, 0, 0, 0], 
                filename:     `@Model.FilePrefix-${cleanInvNo}.pdf`,
                image:        { type: 'jpeg', quality: 1.0 },
                html2canvas:  { scale: 2, useCORS: true, logging: false, letterRendering: true },
                jsPDF:        { unit: 'mm', format: 'a4', orientation: 'portrait' }
            };

            html2pdf().set(opt).from(element).save().then(() => {
                document.getElementById('loading-overlay').innerText = "Unduhan berhasil!";
                setTimeout(() => {
                    window.close();
                }, 600);
            }).catch(err => {
                console.error("Gagal cetak berkas:", err);
                document.getElementById('loading-overlay').innerHTML = "<span style='color:red;'>Gagal mengunduh otomatis. Silakan gunakan kombinasi pintasan Ctrl+P.</span>";
            });
        }
    </script>
</body>
</html>
