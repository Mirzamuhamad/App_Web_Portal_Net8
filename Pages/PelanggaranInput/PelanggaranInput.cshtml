@page
@model TestLandingPageNet8.Pages.Pelanggaran.InputModel
@{
    Layout = null; // Menghilangkan Header dan Footer agar fokus di HP petugas/security
}

<!DOCTYPE html>
<html lang="id">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Lapor Pelanggaran Area</title>
    <script src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js" defer></script>
    <script
    src="https://cdn.jsdelivr.net/npm/browser-image-compression@2.0.2/dist/browser-image-compression.js"></script>
    <link href="https://cdn.jsdelivr.net/npm/remixicon@3.5.0/fonts/remixicon.css" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Mulish:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <style>
        body {
        font-family: 'Mulish', sans-serif;
        }

        input[type="datetime-local"] {
        min-height: 3rem;
        -webkit-appearance: listbox;
        }

        .ios-datetime-fix::-webkit-date-and-time-value {
        text-align: left;
        min-height: 1.25em;
        color: #1e293b;
        }
    </style>
</head>

<body class="bg-slate-50/50">

    <div class="min-h-screen py-4 px-2 sm:py-4 sm:px-4" x-data="violationForm()">
        <div class=" mx-auto">

           <div class="flex items-center justify-between mb-4 bg-slate-900 text-white p-4 rounded-3xl shadow-md">
    <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-xl bg-rose-500 flex items-center justify-center flex-shrink-0 animate-pulse">
            <i class="ri-radar-line text-xl"></i>
        </div>
        <div>
            <h2 class="text-base font-bold tracking-tight">Security Patrol Portal</h2>
            <p class="text-[11px] text-slate-300">Pencatatan ketidaksesuaian area.</p>
        </div>
    </div>
    
    <button type="button" 
            @@click="triggerLogout()"
            class="w-9 h-9 rounded-xl bg-white/10 hover:bg-rose-500/20 hover:text-rose-400 flex items-center justify-center transition border border-white/5 active:scale-90" 
            title="Keluar / Ganti Shift">
        <i class="ri-logout-box-r-line text-lg"></i>
    </button>
</div>

            <form x-ref="form" enctype="multipart/form-data"
                  class="bg-white p-5 rounded-[2.5rem] shadow-xl shadow-slate-200/40 border border-slate-100 space-y-4">
                @Html.AntiForgeryToken()

                <input type="hidden" name="Input.KavlingId" value="" />
                <input type="hidden" name="Input.FineAmount" value="0" />

                <div class="space-y-1">
                    <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Jenis
                        Pelanggaran</label>
                        <input type="text" name="Input.ViolationType" required
                               placeholder="Contoh: Parkir Sembarangan, Sampah Liar"
                               class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none transition">
                    </div>

                    <div class="space-y-1">
                        <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Kronologi /
                            Detail Kejadian</label>
                            <textarea name="Input.Description" required rows="3"
                                      placeholder="Jelaskan detail kendaraan atau kronologi objek pelanggaran..."
                                      class="w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none transition resize-none"></textarea>
                        </div>

                        <div class="space-y-1">
                            <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Waktu
                                Kejadian</label>
                                <input type="datetime-local" name="Input.ViolationDate" required
                                       class="ios-datetime-fix w-full bg-slate-50 border border-slate-200 rounded-2xl px-4 py-3.5 text-sm text-slate-800 focus:ring-2 focus:ring-rose-500/20 focus:border-rose-500 outline-none transition"
                                       style="height: 3.25rem;">
                            </div>

                            <div class="space-y-3">
                                <label class="text-[10px] font-bold text-slate-400 uppercase tracking-widest ml-1">Foto Bukti
                                    Lapangan (Maks. 3)</label>

                                    <div class="grid grid-cols-3 gap-3">
                                        <template x-for="(img, index) in previews" :key="index">
                                            <div
                                                class="relative aspect-square rounded-2xl overflow-hidden border border-slate-100 shadow-sm">
                                                <img :src="img" class="w-full h-full object-cover">
                                                <button type="button" @@click="removeImage(index)"
                                                        class="absolute top-1 right-1 bg-rose-500/90 text-white w-6 h-6 rounded-lg backdrop-blur-sm flex items-center justify-center hover:bg-rose-600 transition">
                                                    <i class="ri-close-line"></i>
                                                </button>
                                            </div>
                                        </template>

                                        <label x-show="previews.length < 3"
                                               class="aspect-square rounded-2xl border-2 border-dashed border-rose-200 flex flex-col items-center justify-center cursor-pointer hover:border-rose-500 hover:bg-rose-50/30 transition group text-center p-2 col-span-1">
                                            <i
                                            class="ri-camera-lens-line text-2xl text-rose-400 group-hover:scale-110 transition-transform"></i>
                                            <span class="text-[9px] font-black text-rose-500 mt-1">Tambah Foto</span>
                                            <input type="file" multiple accept="image/*" class="hidden"
                                            @@change="processUpload($event)">
                                        </label>
                                    </div>
                                </div>

                                <div x-show="compressing" class="p-4 bg-rose-50 rounded-2xl border border-rose-100 animate-pulse">
                                    <div class="flex justify-between items-center mb-2">
                                        <span class="text-[10px] font-bold text-rose-600 uppercase tracking-widest">Mengoptimalkan
                                            Ukuran Gambar...</span>
                                            <span class="text-xs font-bold text-rose-600" x-text="compressProgress + '%'"></span>
                                        </div>
                                        <div class="w-full bg-slate-200 rounded-full h-1.5 overflow-hidden">
                                            <div class="bg-rose-500 h-full transition-all duration-300"
                                                 :style="'width: ' + compressProgress + '%'"></div>
                                        </div>
                                    </div>

                                    <div class="pt-2">
                                        <button type="button" :disabled="loading || compressing" @@click="submitForm()"
                                                class="w-full bg-rose-600 hover:bg-rose-700 disabled:bg-slate-300 text-white font-black py-4 rounded-2xl shadow-lg shadow-rose-100 transition-all flex items-center justify-center gap-3">
                                            <template x-if="loading">
                                                <i class="ri-loader-4-line animate-spin text-xl"></i>
                                            </template>
                                            <span x-text="loading ? 'Kirim Laporan Pelanggaran' : 'Kirim Laporan Pelanggaran'"></span>
                                        </button>
                                    </div>
                                </form>
                            </div>
                        </div>

                        <script>
    function violationForm() {
        return {
            previews: [],
            compressedFiles: [],
            loading: false,
            compressing: false,
            compressProgress: 0,

            async processUpload(event) {
                const files = Array.from(event.target.files);
                if (this.previews.length + files.length > 3) {
                    Swal.fire({ icon: 'warning', title: 'Batas Maksimal', text: 'Maksimal lampiran bukti hanya 3 foto.' });
                    return;
                }

                this.compressing = true;
                for (const file of files) {
                    try {
                        const options = {
                            maxSizeMB: 1,
                            maxWidthOrHeight: 1280,
                            useWebWorker: true,
                            onProgress: (p) => { this.compressProgress = p; }
                        };
                        const compressedFile = await imageCompression(file, options);
                        this.compressedFiles.push(compressedFile);

                        const reader = new FileReader();
                        reader.onload = (e) => this.previews.push(e.target.result);
                        reader.readAsDataURL(compressedFile);
                    } catch (error) {
                        console.error('Compression error:', error);
                    }
                }
                this.compressing = false;
                this.compressProgress = 0;
                event.target.value = '';
            },

            removeImage(index) {
                this.previews.splice(index, 1);
                this.compressedFiles.splice(index, 1);
            },

            // Tambahkan fungsi konfirmasi logout di sini agar menyatu dengan Alpine.js
            triggerLogout() {
                Swal.fire({
                    title: '',
                    text: "Anda akan keluar dari sistem patroli kawasan.",
                    icon: 'question',
                    showCancelButton: true,
                    confirmButtonColor: '#e11d48', // Warna Rose-600 matching tema UI Anda
                    cancelButtonColor: '#64748b',  // Warna Slate-500
                    confirmButtonText: 'Ya, Keluar',
                    cancelButtonText: 'Batal',
                    background: '#ffffff',
                    customClass: {
                        popup: 'rounded-[2rem]' // Menyelaraskan bentuk rounded dengan box form utama
                    }
                }).then((result) => {
                    if (result.isConfirmed) {
                        // Memanggil Named Handler OnGetLogoutAsync() di backend .cshtml.cs
                        window.location.href = '?handler=Logout';
                    }
                });
            },

            async submitForm() {
                if (!this.$refs.form.reportValidity()) return;

                this.loading = true;
                const formData = new FormData();

                // Ambil value dari hidden input secara aman
                const kavlingVal = this.$refs.form.querySelector('[name="Input.KavlingId"]').value;
                const fineVal = this.$refs.form.querySelector('[name="Input.FineAmount"]').value;

                formData.append('Input.KavlingId', kavlingVal);
                formData.append('Input.ViolationType', this.$refs.form.querySelector('[name="Input.ViolationType"]').value);
                formData.append('Input.FineAmount', fineVal);
                formData.append('Input.Description', this.$refs.form.querySelector('[name="Input.Description"]').value);
                formData.append('Input.ViolationDate', this.$refs.form.querySelector('[name="Input.ViolationDate"]').value);

                this.compressedFiles.forEach((file) => {
                    formData.append('Input.Photos', file, file.name);
                });

                try {
                    const response = await fetch('', {
                        method: 'POST',
                        body: formData,
                        headers: { 'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]').value }
                    });
                    const result = await response.json();
                    if (result.success) {
                        this.$refs.form.reset();
                        this.previews = [];
                        this.compressedFiles = [];
                        Swal.fire({ icon: 'success', title: 'Berhasil!', text: result.message, confirmButtonColor: '#e11d48' })
                            .then(() => window.location.reload());
                    } else {
                        Swal.fire({ icon: 'warning', title: 'Gagal', text: result.message });
                    }
                } catch (e) {
                    Swal.fire({ icon: 'error', title: 'Error', text: 'Terjadi kegagalan koneksi ke server.' });
                } finally {
                    this.loading = false;
                }
            }
        }
    }
</script>
                    </body>

                </html>